{
  "tagFields": {
    "container": {
      "uuid": "tag_fields_collapse_container",
      "name": "Tag Fields Container",
      "style": {}
    },
    "collapse": {
      "uuid": "tag_fields_collapse",
      "title": "Tag Properties"
    },
    "properties": [
      {
        "name": "labelaa",
        "label": "Label",
        "type": "text",
        "default": "",
        "width": "180px",
        "placeholder": "Tag label",
        "valueHandler": {
          "ref": "componentInput",
          "params": ["label"]
        },
        "stateHandler": {
          "ref": "inputHandler",
          "params": ["label"]
        },
        "eventHandlers": {
          "onChange": {
            "ref": "updateInput",
            "params": ["label", "string"]
          }
        }
      },
      {
        "name": "closable",
        "label": "Closable",
        "type": "boolean",
        "inputProperty": "closable",
        "default": false,
        "width": "180px",
        "hasHandler": true,
        "handlerType": "input",
        "stateHandler": {
          "ref": "inputHandler",
          "params": ["closable"]
        },
        "handlerProperty": "closable"
      },
      {
        "name": "icon_tag",
        "label": "Icon",
        "type": "icon",
        "inputProperty": "icon",
        "default": "",
        "width": "180px",
        "placeholder": "Choose an icon",
        "valueHandler": {
          "ref": "componentInput",
          "params": ["icon"]
        },
        "stateHandler": {
          "ref": "inputHandler",
          "params": ["icon"]
        },
        "eventHandlers": {
          "onChange": {
            "ref": "updateInput",
            "params": ["icon", "value"]
          }
        }
      },
      {
        "name": "bordered_tag",
        "label": "Bordered",
        "type": "boolean",
        "inputProperty": "bordered",
        "default": true,
        "width": "180px",
        "hasHandler": true,
        "handlerType": "input",
        "stateHandler": {
          "ref": "inputHandler",
          "params": ["bordered"]
        },
        "handlerProperty": "bordered"
      }
    ]
  }
}
