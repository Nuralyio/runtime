{
  "selectFields": {
    "container": {
      "uuid": "select_collapse_container",
      "name": "Select Fields Container",
      "style": {}
    },
    "collapse": {
      "uuid": "select_collapse",
      "title": "Select Properties"
    },
    "properties": [
      {
        "name": "label",
        "label": "Label",
        "type": "text",
        "default": "",
        "width": "180px",
        "placeholder": "Select label",
        "valueHandler": { "ref": "componentInput", "params": ["label"] },
        "stateHandler": { "ref": "inputHandler", "params": ["label"] },
        "eventHandlers": {
          "onChange": { "ref": "updateInput", "params": ["label", "value"] }
        }
      },
      {
        "name": "placeholder",
        "label": "Placeholder",
        "type": "text",
        "default": "Select an option",
        "width": "180px",
        "placeholder": "Placeholder text",
        "valueHandler": { "ref": "componentInput", "params": ["placeholder"] },
        "stateHandler": { "ref": "inputHandler", "params": ["placeholder"] },
        "eventHandlers": {
          "onChange": { "ref": "updateInput", "params": ["placeholder", "value"] }
        }
      },
      {
        "name": "options",
        "label": "Options",
        "type": "event",
        "default": "",
        "width": "50px",
        "handlerType": "input",
        "handlerProperty": "options",
        "handlerValueGetter": "const parameter = 'options'; let valueHandler = ''; const selectedComponent = Utils.first($selectedComponents); if(selectedComponent.input?.options?.type =='handler' && selectedComponent.input?.options?.value){ valueHandler = selectedComponent.input?.options?.value } return [parameter, valueHandler];",
        "handlerEventUpdate": "const selectedComponent = Utils.first($selectedComponents); if(EventData.value != selectedComponent.input?.options?.value) updateInput(selectedComponent,'options','handler',EventData.value);"
      },
      {
        "name": "select_value",
        "inputProperty": "value",
        "label": "Value",
        "type": "text",
        "default": "",
        "width": "180px",
        "placeholder": "Selected value",
        "valueHandler": { "ref": "componentInput", "params": ["value"] },
        "stateHandler": { "ref": "inputHandler", "params": ["value"] },
        "eventHandlers": {
          "onChange": { "ref": "updateInput", "params": ["value", "value"] }
        }
      },
      {
        "name": "select_type",
        "inputProperty": "type",
        "label": "Type",
        "type": "radio",
        "default": "default",
        "width": "180px",
        "options": [
          { "label": "Default", "value": "default" },
          { "label": "Inline", "value": "inline" }
        ],
        "stateHandler": { "ref": "inputHandler", "params": ["type"] },
        "eventHandlers": {
          "onChange": { "ref": "updateInput", "params": ["type", "value"] }
        },
        "hasHandler": true,
        "handlerType": "input",
        "handlerProperty": "type"
      },
      {
        "name": "select_selection_mode",
        "inputProperty": "selectionMode",
        "label": "Selection Mode",
        "type": "radio",
        "default": "single",
        "width": "180px",
        "options": [
          { "label": "Single", "value": "single" },
          { "label": "Multiple", "value": "multiple" }
        ],
        "stateHandler": { "ref": "inputHandler", "params": ["selectionMode"] },
        "eventHandlers": {
          "onChange": { "ref": "updateInput", "params": ["selectionMode", "value"] }
        },
        "hasHandler": true,
        "handlerType": "input",
        "handlerProperty": "selectionMode"
      },
      {
        "name": "sizeselect",
        "inputProperty": "size",
        "label": "Size",
        "type": "radio",
        "default": "medium",
        "width": "180px",
        "options": [
          { "label": "Small", "value": "small" },
          { "label": "Medium", "value": "medium" },
          { "label": "Large", "value": "large" }
        ],
        "stateHandler": { "ref": "inputHandler", "params": ["size"] },
        "eventHandlers": {
          "onChange": { "ref": "updateInput", "params": ["size", "value"] }
        },
        "hasHandler": true,
        "handlerType": "input",
        "handlerProperty": "size"
      },
      {
        "name": "searchable",
        "inputProperty": "searchable",
        "label": "Searchable",
        "type": "boolean",
        "default": false,
        "width": "180px",
        "stateHandler": { "ref": "inputHandler", "params": ["searchable"] },
        "hasHandler": true,
        "handlerType": "input",
        "handlerProperty": "searchable"
      },
      {
        "name": "searchPlaceholder",
        "label": "Search Placeholder",
        "type": "text",
        "default": "Search options...",
        "width": "180px",
        "placeholder": "Search placeholder text",
        "valueHandler": { "ref": "componentInput", "params": ["searchPlaceholder"] },
        "stateHandler": { "ref": "inputHandler", "params": ["searchPlaceholder"] },
        "eventHandlers": {
          "onChange": { "ref": "updateInput", "params": ["searchPlaceholder", "value"] }
        }
      },
      {
        "name": "clearable",
        "inputProperty": "clearable",
        "label": "Clearable",
        "type": "boolean",
        "default": false,
        "width": "180px",
        "stateHandler": { "ref": "inputHandler", "params": ["clearable"] },
        "hasHandler": true,
        "handlerType": "input",
        "handlerProperty": "clearable"
      },
      {
        "name": "disabled",
        "inputProperty": "disabled",
        "label": "Disabled",
        "type": "boolean",
        "default": false,
        "width": "180px",
        "stateHandler": { "ref": "inputHandler", "params": ["disabled"] },
        "hasHandler": true,
        "handlerType": "input",
        "handlerProperty": "disabled"
      }
    ],
    "includeCommonProperties": [
      "component_value_text_block",
      "component_id_text_block",
      "display_block", "access_block",
      "component_hash_text_block"
    ],
    "includeContainers": []
  }
}
