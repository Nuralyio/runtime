        "placeholder": "Enter value",
        "valueHandler": { "ref": "componentInput", "params": ["value"] },
        "stateHandler": { "ref": "inputHandler", "params": ["value"] },
        "eventHandlers": {
          "valueChange": { "ref": "updateInput", "params": ["value", "value"] }
        },
        "hasHandler": true,
        "handlerType": "input",
        "handlerProperty": "value"
      },
      {
        "name": "label",
        "inputProperty": "label",
        "label": "Label",
        "type": "text",
        "default": "",
