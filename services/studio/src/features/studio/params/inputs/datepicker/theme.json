      },
      {
        "name": "States & Opacity",
        "open": false,
        "items": [
          { "label": "Disabled Opacity", "cssVar": "--nuraly-datepicker-local-disabled-opacity", "type": "text", "placeholder": "0.5", "defaultValue": "0.5" },
          { "label": "Hover Opacity", "cssVar": "--nuraly-datepicker-local-hover-opacity", "type": "text", "placeholder": "0.8", "defaultValue": "0.8" }
