          { "label": "Transition Timing", "cssVar": "--nuraly-datepicker-local-transition-timing", "type": "select", "options": [
            { "label": "Ease", "value": "ease" },
            { "label": "Ease In", "value": "ease-in" },
            { "label": "Ease Out", "value": "ease-out" },
            { "label": "Ease In Out", "value": "ease-in-out" },
            { "label": "Linear", "value": "linear" }
          ], "defaultValue": "ease-in-out" },
          { "label": "Calendar Animation Duration", "cssVar": "--nuraly-datepicker-local-calendar-animation-duration", "type": "text", "placeholder": "0.15s", "defaultValue": "0.15s" }
        ]
