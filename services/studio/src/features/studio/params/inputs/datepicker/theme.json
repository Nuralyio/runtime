        "items": [
          { "label": "Medium Font Size", "cssVar": "--nuraly-datepicker-local-medium-font-size", "type": "text", "placeholder": "14px", "defaultValue": "14px" },
          { "label": "Medium Padding", "cssVar": "--nuraly-datepicker-local-medium-padding", "type": "text", "placeholder": "8px 12px", "defaultValue": "8px 12px" },
          { "label": "Medium Height", "cssVar": "--nuraly-datepicker-local-medium-height", "type": "text", "placeholder": "36px", "defaultValue": "36px" },
          { "label": "Medium Day Size", "cssVar": "--nuraly-datepicker-local-medium-day-size", "type": "text", "placeholder": "36px", "defaultValue": "36px" }
        ]
