          { "label": "Input Focus Shadow", "cssVar": "--nuraly-datepicker-local-input-focus-shadow", "type": "text", "placeholder": "0 0 0 2px rgba(22,119,255,0.2)", "defaultValue": "0 0 0 2px rgba(22, 119, 255, 0.2)" }
