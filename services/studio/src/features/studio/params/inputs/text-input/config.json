      {
        "name": "textinput_type",
        "inputProperty": "type",
        "label": "Type",
        "type": "radio",
        "default": "text",
        "width": "180px",
        "valueHandler": "const selectedComponent = Utils.first($selectedComponents);\nlet currentType = '';\nlet isDisabled = false;\nif (selectedComponent?.input?.type?.type == 'handler' && selectedComponent?.input?.type?.value) {\n  isDisabled = true;\n} else {\n  currentType = selectedComponent?.input?.type?.value || 'text';\n}\nconst options = [\n  { value: 'text', icon: 'font', disabled: isDisabled },\n  { value: 'password', icon: 'lock', disabled: isDisabled },\n  { value: 'email', icon: 'envelope', disabled: isDisabled },\n  { value: 'number', icon: 'hashtag', disabled: isDisabled }\n];\nconst radioType = 'button';\nreturn [options, currentType, radioType];",
        "eventHandlers": {
          "changed": "const selectedComponent = Utils.first($selectedComponents);\nif (selectedComponent) {\n  updateInput(selectedComponent, 'type', 'string', EventData.value);\n}"
        },
        "hasHandler": true,
        "handlerType": "input",
        "handlerProperty": "type"
      },
      {
        "name": "textinput_size",
        "inputProperty": "size",
        "label": "Size",
        "type": "radio",
        "default": "medium",
        "width": "180px",
        "options": [
          { "label": "Small", "value": "small" },
          { "label": "Medium", "value": "medium" },
          { "label": "Large", "value": "large" }
        ],
        "valueHandler": {
          "ref": "componentInput",
          "params": ["size"]
        },
        "stateHandler": {
          "ref": "inputHandler",
          "params": ["size"]
        },
        "eventHandlers": {
