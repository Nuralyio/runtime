      {
        "name": "textinput_status",
        "inputProperty": "status",
        "label": "Status",
        "type": "radio",
        "default": "default",
        "width": "180px",
        "valueHandler": "const selectedComponent = Utils.first($selectedComponents);\nlet isDisabled = false;\nlet currentStatus = '';\nif (selectedComponent?.input?.status?.type == 'handler' && selectedComponent?.input?.status?.value != '') {\n  isDisabled = true;\n} else {\n  currentStatus = selectedComponent?.input?.status?.value || 'default';\n}\nconst options = [\n  { value: 'default', icon: 'font-awesome', disabled: isDisabled },\n  { value: 'warning', icon: 'triangle-exclamation', disabled: isDisabled },\n  { value: 'error', icon: 'circle-exclamation', disabled: isDisabled }\n];\nconst radioType = 'button';\nreturn [options, currentStatus, radioType];",
        "eventHandlers": {
          "changed": "const selectedComponent = Utils.first($selectedComponents);\nconst statusValue = EventData.value ? EventData.value : 'default';\nupdateInput(selectedComponent, 'status', 'string', statusValue);"
        },
        "hasHandler": true,
        "handlerType": "input",
        "handlerProperty": "status",
        "handlerValueGetter": "const parameter = 'status';\nlet statusHandler = '';\nconst selectedComponent = Utils.first($selectedComponents);\nif (selectedComponent?.input?.status?.type == 'handler') {\n  statusHandler = selectedComponent?.input?.status?.value || '';\n}\nreturn [parameter, statusHandler];",
        "handlerEventUpdate": "updateInput(Utils.first($selectedComponents), 'status', 'handler', EventData.value);"
      },
