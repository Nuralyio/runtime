        "name": "textinput_variant",
        "inputProperty": "variant",
        "label": "Variant",
        "type": "radio",
        "default": "outlined",
        "width": "180px",
        "options": [
          { "label": "Outlined", "value": "outlined" },
          { "label": "Filled", "value": "filled" },
          { "label": "Underlined", "value": "underlined" },
          { "label": "Borderless", "value": "borderless" }
        ],
        "valueHandler": {
          "ref": "componentInput",
          "params": ["variant"]
        },
        "stateHandler": {
          "ref": "inputHandler",
          "params": ["variant"]
        },
        "eventHandlers": {
          "onChange": {
            "ref": "updateInput",
            "params": ["variant", "string"]
