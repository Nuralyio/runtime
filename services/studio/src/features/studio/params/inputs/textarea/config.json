        "handlerProperty": "variant"
      },
      {
        "name": "textarea_state",
        "inputProperty": "state",
        "label": "State",
        "type": "radio",
        "default": "default",
        "width": "180px",
        "valueHandler": "const selectedComponent = Utils.first($selectedComponents);\nlet isDisabled = false;\nlet currentState = '';\nif (selectedComponent?.input?.state?.type == 'handler' && selectedComponent?.input?.state?.value != '') {\n  isDisabled = true;\n} else {\n  currentState = selectedComponent?.input?.state?.value || 'default';\n}\nconst options = [\n  { value: 'default', icon: 'font-awesome', disabled: isDisabled },\n  { value: 'warning', icon: 'triangle-exclamation', disabled: isDisabled },\n  { value: 'error', icon: 'circle-exclamation', disabled: isDisabled },\n  { value: 'success', icon: 'circle-check', disabled: isDisabled }\n];\nconst radioType = 'button';\nreturn [options, currentState, radioType];",
        "eventHandlers": {
          "changed": "const selectedComponent = Utils.first($selectedComponents);\nconst stateValue = EventData.value ? EventData.value : 'default';\nupdateInput(selectedComponent, 'state', 'string', stateValue);"
        },
        "hasHandler": true,
        "handlerType": "input",
        "handlerProperty": "state",
        "handlerValueGetter": "const parameter = 'state';\nlet stateHandler = '';\nconst selectedComponent = Utils.first($selectedComponents);\nif (selectedComponent?.input?.state?.type == 'handler') {\n  stateHandler = selectedComponent?.input?.state?.value || '';\n}\nreturn [parameter, stateHandler];",
        "handlerEventUpdate": "updateInput(Utils.first($selectedComponents), 'state', 'handler', EventData.value);"
      },
