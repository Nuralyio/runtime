        "name": "textarea_size",
        "inputProperty": "size",
        "label": "Size",
        "type": "radio",
        "default": "medium",
        "width": "180px",
        "valueHandler": "const selectedComponent = Utils.first($selectedComponents);\nlet currentSize = '';\nlet isDisabled = false;\nif (selectedComponent?.input?.size?.type == 'handler' && selectedComponent?.input?.size?.value) {\n  isDisabled = true;\n} else {\n  currentSize = selectedComponent?.input?.size?.value || 'medium';\n}\nconst options = [\n  { value: 'small', label: 'Small', disabled: isDisabled },\n  { value: 'medium', label: 'Medium', disabled: isDisabled },\n  { value: 'large', label: 'Large', disabled: isDisabled }\n];\nconst radioType = 'default';\nreturn [options, currentSize, radioType];",
        "eventHandlers": {
          "changed": "const selectedComponent = Utils.first($selectedComponents);\nif (selectedComponent) {\n  updateInput(selectedComponent, 'size', 'string', EventData.value);\n}"
        },
        "hasHandler": true,
        "handlerType": "input",
        "handlerProperty": "size"
      },
      {
        "name": "textarea_variant",
        "inputProperty": "variant",
        "label": "Variant",
        "type": "radio",
        "default": "underlined",
        "width": "180px",
        "valueHandler": "const selectedComponent = Utils.first($selectedComponents);\nlet currentVariant = '';\nlet isDisabled = false;\nif (selectedComponent?.input?.variant?.type == 'handler' && selectedComponent?.input?.variant?.value) {\n  isDisabled = true;\n} else {\n  currentVariant = selectedComponent?.input?.variant?.value || 'underlined';\n}\nconst options = [\n  { value: 'outlined', label: 'Outlined', disabled: isDisabled },\n  { value: 'filled', label: 'Filled', disabled: isDisabled },\n  { value: 'underlined', label: 'Underlined', disabled: isDisabled }\n];\nconst radioType = 'default';\nreturn [options, currentVariant, radioType];",
        "eventHandlers": {
          "changed": "const selectedComponent = Utils.first($selectedComponents);\nif (selectedComponent) {\n  updateInput(selectedComponent, 'variant', 'string', EventData.value);\n}"
        },
        "hasHandler": true,
