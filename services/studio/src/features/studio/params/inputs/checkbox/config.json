{
  "checkboxFields": {
    "container": {
      "uuid": "checkbox_collapse_container",
      "name": "Checkbox Fields Container",
      "style": {}
    },
    "collapse": {
      "uuid": "checkbox_collapse",
      "title": "Checkbox Properties"
    },
    "properties": [
      {
        "name": "label",
        "label": "Label",
        "type": "text",
        "default": "Checkbox",
        "width": "180px",
        "placeholder": "Checkbox label",
        "valueHandler": "const selectedComponent = Utils.first($selectedComponents); const input = Editor.getComponentBreakpointInput(selectedComponent, 'label'); if (input?.type === 'handler' && input?.value) { return 'Checkbox'; } return input?.type === 'value' ? (input.value || 'Checkbox') : 'Checkbox';",
        "stateHandler": { "ref": "inputHandler", "params": ["label"] },
        "eventHandlers": {
          "valueChange": { "ref": "updateInput", "params": ["label", "value"] }
        }
      },
      {
        "name": "id",
        "label": "ID",
        "type": "text",
        "default": "",
        "width": "180px",
        "placeholder": "Component ID",
        "valueHandler": { "ref": "componentInput", "params": ["id"] },
        "stateHandler": { "ref": "inputHandler", "params": ["id"] },
        "eventHandlers": {
          "valueChange": { "ref": "updateInput", "params": ["id", "value"] }
        }
      },
      {
        "name": "checked",
        "label": "State",
        "type": "radio",
        "default": false,
        "width": "180px",
        "inputProperty": "value",
        "options": [
          { "label": "✓", "value": true },
          { "label": "✗", "value": false },
          { "label": "—", "value": "indeterminate" }
        ],
        "stateHandler": { "ref": "inputHandler", "params": ["value"] },
        "eventHandlers": {
          "onChange": { "ref": "updateInput", "params": ["value", "value"] }
        },
        "hasHandler": true,
        "handlerType": "input",
        "handlerProperty": "value"
      },
      {
        "name": "sizeoption",
        "inputProperty": "size",
        "label": "Size",
        "type": "radio",
        "default": "medium",
        "width": "180px",
        "options": [
          { "label": "Small", "value": "small" },
          { "label": "Medium", "value": "medium" },
          { "label": "Large", "value": "large" }
        ],
        "stateHandler": { "ref": "inputHandler", "params": ["size"] },
        "eventHandlers": {
          "onChange": { "ref": "updateInput", "params": ["size", "value"] }
        },
        "hasHandler": true,
        "handlerType": "input",
        "handlerProperty": "size"
      },

      {
        "name": "checboxdisabled",
        "inputProperty": "disabled",
        "label": "Disabled",
        "type": "boolean",
        "default": false,
        "width": "180px",
        "stateHandler": { "ref": "inputHandler", "params": ["disabled"] },
        "hasHandler": true,
        "handlerType": "input",
        "handlerProperty": "disabled"
      }
    ],
    "includeCommonProperties": [
      "component_value_text_block",
      "component_id_text_block",
      "display_block",
      "component_hash_text_block"
    ],
    "includeContainers": []
  }
}
