{
  "checkboxFields": {
    "container": {
      "uuid": "checkbox_collapse_container",
      "name": "Checkbox Fields Container",
      "style": {}
    },
    "collapse": {
      "uuid": "checkbox_collapse",
      "title": "Checkbox Properties"
    },
    "properties": [
      {
        "name": "label",
        "label": "Label",
        "type": "text",
        "default": "Checkbox",
        "width": "180px",
        "placeholder": "Checkbox label",
        "valueHandler": "const selectedComponent = Utils.first(Vars.selectedComponents); if (selectedComponent?.inputHandlers?.label) { return selectedComponent.inputHandlers.label; } const input = Editor.getComponentBreakpointInput(selectedComponent, 'label'); return input?.type === 'value' ? (input.value || 'Checkbox') : 'Checkbox';",
        "stateHandler": { "ref": "inputHandler", "params": ["label"] },
        "eventHandlers": {
          "valueChange": { "ref": "updateInput", "params": ["label", "value"] }
        }
      },
      {
        "name": "id",
        "label": "ID",
        "type": "text",
        "default": "",
        "width": "180px",
        "placeholder": "Component ID",
        "valueHandler": { "ref": "componentInput", "params": ["id"] },
        "stateHandler": { "ref": "inputHandler", "params": ["id"] },
        "eventHandlers": {
          "valueChange": { "ref": "updateInput", "params": ["id", "value"] }
        }
      },
      {
        "name": "checked",
        "label": "State",
        "type": "radio",
        "default": false,
        "width": "180px",
        "options": [
          { "label": "✓", "value": true },
          { "label": "✗", "value": false },
          { "label": "—", "value": "indeterminate" }
        ],
        "valueHandler": { "ref": "componentInputRadio", "params": ["value", [{"label": "✓ ", "value": true}, {"label": "✗ ", "value": false}, {"label": "— ", "value": "indeterminate"}], false] },
        "stateHandler": { "ref": "inputHandler", "params": ["value"] },
        "eventHandlers": {
          "onChange": { "ref": "updateInput", "params": ["value", "mixed"] }
        },
        "hasHandler": true,
        "handlerType": "input",
        "handlerProperty": "onChange"
      },
      {
        "name": "sizeoption",
        "label": "Size",
        "type": "radio",
        "default": "medium",
        "width": "180px",
        "options": [
          { "label": "Small", "value": "small" },
          { "label": "Medium", "value": "medium" },
          { "label": "Large", "value": "large" }
        ],
        "valueHandler": { "ref": "componentInputRadio", "params": ["size", [{"label": "Small", "value": "small"}, {"label": "Medium", "value": "medium"}, {"label": "Large", "value": "large"}], "medium"] },
        "stateHandler": { "ref": "inputHandler", "params": ["size"] },
        "eventHandlers": {
          "onChange": { "ref": "updateInput", "params": ["size", "string"] }
        }
      },
      
      {
        "name": "disabled",
        "label": "Disabled",
        "type": "boolean",
        "default": false,
        "width": "180px",
        "valueHandler": "const selectedComponent = Utils.first(Vars.selectedComponents); const input = Editor.getComponentBreakpointInput(selectedComponent, 'disabled'); return input?.type === 'value' ? (input.value ?? false) : false;",
        "stateHandler": { "ref": "inputHandler", "params": ["disabled"] }
      },
      {
        "name": "required",
        "label": "Required",
        "type": "boolean",
        "default": false,
        "width": "180px",
        "valueHandler": { "ref": "componentInput", "params": ["required", false] },
        "stateHandler": { "ref": "inputHandler", "params": ["required"] }
      }
    ]
  }
}
