{
  "textLabelFields": {
    "container": {
      "uuid": "text_label_properties_collapse_container",
      "name": "Text Label Properties Container",
      "style": {}
    },
    "collapse": {
      "uuid": "text_label_properties_collapse",
      "title": "Label Properties",
      "style": {
      }
    },
    "properties": [
      {
        "name": "value",
        "label": "Text",
        "type": "text",
        "default": "Text label",
        "width": "150px",
        "placeholder": "Enter text",
        "valueHandler": {
          "ref": "componentInput",
          "params": ["value"]
        },
        "stateHandler": {
          "ref": "inputHandler",
          "params": ["value"]
        },
        "eventHandlers": {
          "onChange": {
            "ref": "updateInput",
            "params": ["value", "string"]
          }
        },
        "hasHandler": true,
        "handlerType": "input",
        "handlerProperty": "value",
        "translatable": true
      },
      {
        "name": "size",
        "label": "Size",
        "type": "select",
        "default": "medium",
        "width": "180px",
        "options": [
          { "label": "Small", "value": "small" },
          { "label": "Medium", "value": "medium" },
          { "label": "Large", "value": "large" }
        ],
        "valueHandler": {
          "ref": "componentInput",
          "params": ["size"]
        },
        "stateHandler": {
          "ref": "inputHandler",
          "params": ["size"]
        },
        "eventHandlers": {
          "changed": {
            "ref": "updateInput",
            "params": ["size", "string"]
          }
        }
      },
      {
        "name": "variant",
        "label": "Variant",
        "type": "select",
        "default": "default",
        "width": "180px",
        "options": [
          { "label": "Default", "value": "default" },
          { "label": "Secondary", "value": "secondary" },
          { "label": "Success", "value": "success" },
          { "label": "Warning", "value": "warning" },
          { "label": "Error", "value": "error" }
        ],
        "valueHandler": {
          "ref": "componentInput",
          "params": ["variant"]
        },
        "stateHandler": {
          "ref": "inputHandler",
          "params": ["variant"]
        },
        "eventHandlers": {
          "changed": {
            "ref": "updateInput",
            "params": ["variant", "string"]
          }
        }
      },
      {
        "name": "required",
        "label": "Required",
        "type": "boolean",
        "default": false,
        "width": "180px",
        "valueHandler": {
          "ref": "componentInput",
          "params": ["required"]
        },
        "stateHandler": {
          "ref": "inputHandler",
          "params": ["required"]
        }
      },
      {
        "name": "for",
        "label": "For (Input ID)",
        "type": "text",
        "default": "",
        "width": "180px",
        "placeholder": "Enter input ID",
        "valueHandler": {
          "ref": "componentInput",
          "params": ["for"]
        },
        "stateHandler": {
          "ref": "inputHandler",
          "params": ["for"]
        },
        "eventHandlers": {
          "onChange": {
            "ref": "updateInput",
            "params": ["for", "string"]
          }
        }
      }
    ],
    "includeCommonProperties": [
      "component_value_text_block",
      "component_id_text_block",
      "display_block", "access_block",
      "component_hash_text_block"
    ],
    "includeContainers": []
  }
}
