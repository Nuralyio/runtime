{
  "tableFields": {
    "container": {
      "uuid": "table_fields_collapse_container",
      "name": "Table Fields Container",
      "style": {}
    },
    "collapse": {
      "uuid": "table_fields_collapse",
      "title": "Table Properties"
    },
    "properties": [
      {
        "name": "table_data",
        "inputProperty": "data",
        "label": "Data Source",
        "type": "event",
        "default": "",
        "width": "180px",
        "placeholder": "Configure data",
        "hasHandler": true,
        "handlerType": "input",
        "handlerProperty": "data",
        "handlerValueGetter": "const selectedComponent = Utils.first(Vars.selectedComponents);\nreturn selectedComponent?.inputHandlers?.data || '';",
        "handlerEventUpdate": "updateInputHandlers(Utils.first(Vars.selectedComponents), 'data', EventData.value);"
      },
      {
        "name": "table_size",
        "inputProperty": "size",
        "label": "Size",
        "type": "radio",
        "default": "normal",
        "width": "180px",
        "options": [
          { "label": "S", "value": "small" },
          { "label": "M", "value": "normal" },
          { "label": "L", "value": "large" }
        ],
        "stateHandler": {
          "ref": "styleHandler",
          "params": ["size"]
        },
        "eventHandlers": {
          "onChange": {
            "ref": "updateStyle",
            "params": ["size", "value"]
          }
        },
        "hasHandler": true,
        "handlerType": "style",
        "handlerProperty": "size"
      },
      {
        "name": "table_selectionMode",
        "inputProperty": "selectionMode",
        "label": "Selection",
        "type": "radio",
        "default": "",
        "width": "180px",
        "options": [
          { "value": "", "icon": "ban" },
          { "value": "single", "icon": "check" },
          { "value": "multiple", "icon": "list-check" }
        ],
        "stateHandler": {
          "ref": "inputHandler",
          "params": ["selectionMode"]
        },
        "eventHandlers": {
          "onChange": {
            "ref": "updateInput",
            "params": ["selectionMode", "value"]
          }
        },
        "hasHandler": true,
        "handlerType": "input",
        "handlerProperty": "selectionMode"
      },
      {
        "name": "table_filter",
        "inputProperty": "filter",
        "label": "Filter",
        "type": "radio",
        "default": "",
        "width": "180px",
        "options": [
          { "value": "", "icon": "ban" },
          { "value": "filter", "icon": "filter" }
        ],
        "stateHandler": {
          "ref": "inputHandler",
          "params": ["filter"]
        },
        "eventHandlers": {
          "onChange": {
            "ref": "updateInput",
            "params": ["filter", "value"]
          }
        },
        "hasHandler": true,
        "handlerType": "input",
        "handlerProperty": "filter"
      },
      {
        "name": "table_fixedHeader",
        "inputProperty": "fixedHeader",
        "label": "Fixed Header",
        "type": "radio",
        "default": false,
        "width": "180px",
        "options": [
          { "value": false, "icon": "toggle-off" },
          { "value": true, "icon": "toggle-on" }
        ],
        "stateHandler": {
          "ref": "inputHandler",
          "params": ["fixedHeader"]
        },
        "eventHandlers": {
          "onChange": {
            "ref": "updateInput",
            "params": ["fixedHeader", "value"]
          }
        },
        "hasHandler": true,
        "handlerType": "input",
        "handlerProperty": "fixedHeader"
      },
      {
        "name": "table_expandable",
        "inputProperty": "expandable",
        "label": "Expandable Row",
        "type": "text",
        "default": "",
        "width": "180px",
        "placeholder": "Row property key",
        "valueHandler": {
          "ref": "componentInput",
          "params": ["expandable"]
        },
        "stateHandler": {
          "ref": "inputHandler",
          "params": ["expandable"]
        },
        "eventHandlers": {
          "valueChange": {
            "ref": "updateInput",
            "params": ["expandable", "string"]
          }
        },
        "hasHandler": true,
        "handlerType": "input",
        "handlerProperty": "expandable"
      },
      {
        "name": "table_loading",
        "inputProperty": "loading",
        "label": "Loading",
        "type": "boolean",
        "default": false,
        "width": "180px",
        "stateHandler": {
          "ref": "inputHandler",
          "params": ["loading"]
        },
        "hasHandler": true,
        "handlerType": "input",
        "handlerProperty": "loading"
      },
      {
        "name": "table_emptyText",
        "inputProperty": "emptyText",
        "label": "Empty Text",
        "type": "text",
        "default": "No data available",
        "width": "180px",
        "placeholder": "Empty state message",
        "valueHandler": {
          "ref": "componentInput",
          "params": ["emptyText"]
        },
        "stateHandler": {
          "ref": "inputHandler",
          "params": ["emptyText"]
        },
        "eventHandlers": {
          "valueChange": {
            "ref": "updateInput",
            "params": ["emptyText", "string"]
          }
        },
        "hasHandler": true,
        "handlerType": "input",
        "handlerProperty": "emptyText"
      },
      {
        "name": "table_emptyIcon",
        "inputProperty": "emptyIcon",
        "label": "Empty Icon",
        "type": "icon",
        "default": "",
        "width": "180px",
        "placeholder": "Select icon",
        "valueHandler": {
          "ref": "componentInput",
          "params": ["emptyIcon"]
        },
        "stateHandler": {
          "ref": "inputHandler",
          "params": ["emptyIcon"]
        },
        "eventHandlers": {
          "iconChanged": {
            "ref": "updateInput",
            "params": ["emptyIcon", "string"]
          }
        },
        "hasHandler": true,
        "handlerType": "input",
        "handlerProperty": "emptyIcon"
      },
      {
        "name": "table_scrollConfigX",
        "inputProperty": "scrollConfigX",
        "label": "Scroll X",
        "type": "number",
        "default": "",
        "width": "80px",
        "placeholder": "width",
        "valueHandler": {
          "ref": "componentInput",
          "params": ["scrollConfig", "x"]
        },
        "stateHandler": {
          "ref": "inputHandler",
          "params": ["scrollConfig"]
        },
        "eventHandlers": {
          "valueChange": {
            "ref": "updateNestedInput",
            "params": ["scrollConfig", "x", "number"]
          }
        },
        "hasHandler": true,
        "handlerType": "input",
        "handlerProperty": "scrollConfigX"
      },
      {
        "name": "table_scrollConfigY",
        "inputProperty": "scrollConfigY",
        "label": "Scroll Y",
        "type": "number",
        "default": "",
        "width": "80px",
        "placeholder": "height",
        "valueHandler": {
          "ref": "componentInput",
          "params": ["scrollConfig", "y"]
        },
        "stateHandler": {
          "ref": "inputHandler",
          "params": ["scrollConfig"]
        },
        "eventHandlers": {
          "valueChange": {
            "ref": "updateNestedInput",
            "params": ["scrollConfig", "y", "number"]
          }
        },
        "hasHandler": true,
        "handlerType": "input",
        "handlerProperty": "scrollConfigY"
      }
    ]
  }
}
