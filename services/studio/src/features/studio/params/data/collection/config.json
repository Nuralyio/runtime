{
  "collectionFields": {
    "container": {
      "uuid": "collection_collapse_container",
      "name": "Collection Fields Container",
      "style": {}
    },
    "collapse": {
      "uuid": "collection_collapse",
      "title": "Collection Properties"
    },
    "properties": [
      {
        "name": "collection_columns",
        "label": "Columns",
        "type": "number",
        "default": 1,
        "width": "180px",
        "placeholder": "Number of columns",
        "hasHandler": false,
        "valueHandler": {
          "ref": "componentStyle",
          "params": ["--columns", "1"]
        },
        "eventHandlers": {
          "onChange": {
            "ref": "updateStyle",
            "params": ["--columns"]
          }
        }
      },
      {
        "name": "collection_direction",
        "label": "Direction",
        "type": "select",
        "inputProperty": "direction",
        "default": "horizontal",
        "width": "180px",
        "placeholder": "Select direction",
        "options": [
          { "label": "Horizontal", "value": "horizontal" },
          { "label": "Vertical", "value": "vertical" }
        ],
        "hasHandler": true,
        "handlerType": "input",
        "handlerProperty": "direction",
        "valueHandler": {
          "ref": "componentInput",
          "params": ["direction", "horizontal"]
        },
        "stateHandler": {
          "ref": "inputHandler",
          "params": ["direction"]
        },
        "eventHandlers": {
          "onChange": {
            "ref": "updateInput",
            "params": ["direction", "value"]
          }
        }
      },
      {
        "name": "collection_gap",
        "label": "Gap",
        "type": "text",
        "default": "0px",
        "width": "180px",
        "placeholder": "e.g. 10px",
        "hasHandler": true,
        "handlerType": "style",
        "handlerProperty": "gap",
        "valueHandler": {
          "ref": "componentStyle",
          "params": ["gap", "0px"]
        },
        "stateHandler": {
          "ref": "defaultStyle",
          "params": ["gap"]
        },
        "eventHandlers": {
          "onChange": {
            "ref": "updateStyle",
            "params": ["gap"]
          }
        }
      }
    ],
    "includeCommonProperties": [
      "component_id_text_block"
    ],
    "includeContainers": []
  }
}
