{
  "linkFields": {
    "container": {
      "uuid": "link_collapse_container",
      "name": "Link Fields Container",
      "style": {}
    },
    "collapse": {
      "uuid": "link_collapse",
      "title": "Link Properties"
    },
    "properties": [
      {
        "name": "label",
        "label": "Label",
        "type": "text",
        "inputProperty": "label",
        "default": "Link",
        "width": "180px",
        "placeholder": "Link text",
        "hasHandler": true,
        "handlerType": "input",
        "handlerProperty": "label",
        "valueHandler": {
          "ref": "componentInput",
          "params": ["label"]
        },
        "stateHandler": {
          "ref": "inputHandler",
          "params": ["label"]
        },
        "eventHandlers": {
          "onChange": {
            "ref": "updateInput",
            "params": ["label", "string"]
          }
        }
      },
      {
        "name": "url",
        "label": "URL",
        "type": "text",
        "inputProperty": "url",
        "default": "",
        "width": "180px",
        "placeholder": "https://example.com",
        "hasHandler": true,
        "handlerType": "input",
        "handlerProperty": "url",
        "valueHandler": {
          "ref": "componentInput",
          "params": ["url"]
        },
        "stateHandler": {
          "ref": "inputHandler",
          "params": ["url"]
        },
        "eventHandlers": {
          "onChange": {
            "ref": "updateInput",
            "params": ["url", "string"]
          }
        }
      },
      {
        "name": "target",
        "label": "Target",
        "type": "select",
        "inputProperty": "target",
        "default": "_self",
        "width": "180px",
        "options": [
          { "label": "Same Tab (_self)", "value": "_self" },
          { "label": "New Tab (_blank)", "value": "_blank" },
          { "label": "Parent Frame (_parent)", "value": "_parent" },
          { "label": "Top Frame (_top)", "value": "_top" }
        ],
        "hasHandler": true,
        "handlerType": "input",
        "handlerProperty": "target",
        "valueHandler": {
          "ref": "componentInput",
          "params": ["target"]
        },
        "stateHandler": {
          "ref": "inputHandler",
          "params": ["target"]
        },
        "eventHandlers": {
          "onChange": {
            "ref": "updateInput",
            "params": ["target", "value"]
          }
        }
      }
    ],
    "includeCommonProperties": [
      "component_id_text_block"
    ],
    "includeContainers": []
  }
}
