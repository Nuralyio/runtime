{
  "buttonFields": {
    "container": {
      "uuid": "button_collapse_container",
      "name": "Button Fields Container",
      "style": {}
    },
    "collapse": {
      "uuid": "button_collapse",
      "title": "Button Properties",
      "style": {
        "--hy-collapse-content-small-size-padding": "5px",
        "--hy-collapse-font-weight": "normal",
        "--hy-collapse-border-radius": "0px",
        "--hy-collapse-width": "292px",
        "--hy-collapse-border": "none",
        "--hy-collapse-border-bottom": "1px solid #ccc",
        "--hy-collapse-local-header-background-color": "#3d3d3d"
      }
    },
    "properties": [
      {
        "name": "button_label",
        "inputProperty": "label",
        "label": "Label",
        "type": "text",
        "default": "Button",
        "width": "180px",
        "placeholder": "Button text",
        "valueHandler": {
          "ref": "componentInput",
          "params": ["label"]
        },
        "stateHandler": {
          "ref": "inputHandler",
          "params": ["label"]
        },
        "eventHandlers": {
          "valueChange": {
            "ref": "updateInput",
            "params": ["label", "string"]
          }
        },
        "hasHandler": true,
        "handlerType": "input",
        "handlerProperty": "label"
      },
      {
        "name": "button_type",
        "inputProperty": "type",
        "label": "Type",
        "type": "radio",
        "default": "default",
        "width": "180px",
        "valueHandler": "const selectedComponent = Utils.first(Vars.selectedComponents);\nlet currentType = '';\nlet isDisabled = false;\nif (selectedComponent?.input?.type?.type == 'handler' && selectedComponent?.input?.type?.value) {\n  isDisabled = true;\n} else {\n  currentType = selectedComponent?.input?.type?.value || 'default';\n}\nconst options = [\n  { value: 'default', label: 'Default', disabled: isDisabled },\n  { value: 'primary', label: 'Primary', disabled: isDisabled },\n  { value: 'secondary', label: 'Secondary', disabled: isDisabled },\n  { value: 'tertiary', label: 'Tertiary', disabled: isDisabled },\n  { value: 'danger', label: 'Danger', disabled: isDisabled },\n  { value: 'ghost', label: 'Ghost', disabled: isDisabled },\n  { value: 'text', label: 'Text', disabled: isDisabled },\n  { value: 'link', label: 'Link', disabled: isDisabled }\n];\nconst radioType = 'default';\nreturn [options, currentType, radioType];",
        "eventHandlers": {
          "changed": "const selectedComponent = Utils.first(Vars.selectedComponents);\nif (selectedComponent) {\n  updateInput(selectedComponent, 'type', 'string', EventData.value);\n}"
        },
        "hasHandler": true,
        "handlerType": "input",
        "handlerProperty": "type"
      },
      {
        "name": "button_size",
        "inputProperty": "size",
        "label": "Size",
        "type": "radio",
        "default": "medium",
        "width": "180px",
        "valueHandler": "const selectedComponent = Utils.first(Vars.selectedComponents);\nlet currentSize = '';\nlet isDisabled = false;\nif (selectedComponent?.input?.size?.type == 'handler' && selectedComponent?.input?.size?.value) {\n  isDisabled = true;\n} else {\n  currentSize = selectedComponent?.input?.size?.value || 'medium';\n}\nconst options = [\n  { value: 'small', label: 'Small', disabled: isDisabled },\n  { value: 'medium', label: 'Medium', disabled: isDisabled },\n  { value: 'large', label: 'Large', disabled: isDisabled }\n];\nconst radioType = 'default';\nreturn [options, currentSize, radioType];",
        "hasHandler": true,
        "handlerType": "input",
        "handlerProperty": "size"
      },
      {
        "name": "button_shape",
        "inputProperty": "shape",
        "label": "Shape",
        "type": "radio",
        "default": "default",
        "width": "180px",
        "valueHandler": "const selectedComponent = Utils.first(Vars.selectedComponents);\nlet currentShape = '';\nlet isDisabled = false;\nif (selectedComponent?.input?.shape?.type == 'handler' && selectedComponent?.input?.shape?.value) {\n  isDisabled = true;\n} else {\n  currentShape = selectedComponent?.input?.shape?.value || 'default';\n}\nconst options = [\n  { value: 'default', label: 'Default', disabled: isDisabled },\n  { value: 'circle', label: 'Circle', disabled: isDisabled },\n  { value: 'round', label: 'Round', disabled: isDisabled }\n];\nconst radioType = 'default';\nreturn [options, currentShape, radioType];",
        "eventHandlers": {
          "changed": "const selectedComponent = Utils.first(Vars.selectedComponents);\nif (selectedComponent) {\n  updateInput(selectedComponent, 'shape', 'string', EventData.value);\n}"
        },
        "hasHandler": true,
        "handlerType": "input",
        "handlerProperty": "shape"
      },
