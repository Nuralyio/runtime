      {
        "name": "button_iconPosition",
        "inputProperty": "iconPosition",
        "label": "Icon Position",
        "type": "radio",
        "default": "left",
        "width": "180px",
        "valueHandler": "const selectedComponent = Utils.first(Vars.selectedComponents);\nlet currentPosition = '';\nlet isDisabled = false;\nif (selectedComponent?.input?.iconPosition?.type == 'handler' && selectedComponent?.input?.iconPosition?.value) {\n  isDisabled = true;\n} else {\n  currentPosition = selectedComponent?.input?.iconPosition?.value || 'left';\n}\nconst options = [\n  { value: 'left', label: 'Left', disabled: isDisabled },\n  { value: 'right', label: 'Right', disabled: isDisabled }\n];\nconst radioType = 'default';\nreturn [options, currentPosition, radioType];",
        "eventHandlers": {
          "changed": "const selectedComponent = Utils.first(Vars.selectedComponents);\nif (selectedComponent) {\n  updateInput(selectedComponent, 'iconPosition', 'string', EventData.value);\n}"
        },
        "hasHandler": true,
        "handlerType": "input",
        "handlerProperty": "iconPosition"
      },
