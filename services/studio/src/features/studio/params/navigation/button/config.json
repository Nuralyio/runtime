      {
        "name": "button_target",
        "inputProperty": "target",
        "label": "Link Target",
        "type": "select",
        "default": "_self",
        "width": "180px",
        "options": [
          { "label": "Same Tab (_self)", "value": "_self" },
          { "label": "New Tab (_blank)", "value": "_blank" },
          { "label": "Parent Frame (_parent)", "value": "_parent" },
          { "label": "Top Frame (_top)", "value": "_top" }
        ],
        "valueHandler": {
          "ref": "componentInputSelect",
          "params": [
            "target",
            [
              { "label": "Same Tab (_self)", "value": "_self" },
              { "label": "New Tab (_blank)", "value": "_blank" },
              { "label": "Parent Frame (_parent)", "value": "_parent" },
              { "label": "Top Frame (_top)", "value": "_top" }
            ],
            "_self"
          ]
        },
        "stateHandler": {
          "ref": "inputHandler",
          "params": ["target"]
        },
        "eventHandlers": {
