{
  "dropdownFields": {
    "container": {
      "uuid": "dropdown_collapse_container",
      "name": "Dropdown Fields Container",
      "style": {}
    },
    "collapse": {
      "uuid": "dropdown_collapse",
      "title": "Dropdown Properties",
      "style": {
        "--hy-collapse-content-small-size-padding": "5px",
        "--hy-collapse-font-weight": "normal",
        "--hy-collapse-border-radius": "0px",
        "--hy-collapse-width": "292px",
        "--hy-collapse-border": "none",
        "--hy-collapse-border-bottom": "1px solid #ccc",
        "--hy-collapse-local-header-background-color": "#3d3d3d"
      }
    },
    "properties": [
      {
        "name": "dropdown_mode",
        "label": "Mode",
        "type": "select",
        "inputProperty": "mode",
        "default": "options",
        "width": "180px",
        "placeholder": "Select mode",
        "options": [
          { "label": "Options", "value": "options" },
          { "label": "Content", "value": "content" }
        ],
        "hasHandler": false,
        "handlerType": "input",
        "handlerProperty": "mode",
        "valueHandler": {
          "ref": "componentInput",
          "params": ["mode", "options"]
        },
        "stateHandler": {
          "ref": "inputHandler",
          "params": ["mode"]
        },
        "eventHandlers": {
          "onChange": {
            "ref": "updateInput",
            "params": ["mode", "value"]
          }
        }
      },
      {
        "name": "dropdown_editor_open",
        "label": "Editor Open",
        "type": "boolean",
        "inputProperty": "editorOpen",
        "default": false,
        "stateHandler": { "ref": "inputHandler", "params": ["editorOpen"] },
        "hasHandler": false,
        "handlerType": "input",
        "handlerProperty": "editorOpen"
      },
      {
        "name": "options",
        "label": "Options",
        "type": "event",
        "default": "",
        "valueHandler": "const parameter = 'options';\nlet labelHandler = '';\nconst selectedComponent = Utils.first($selectedComponents);\nif (selectedComponent?.input?.options?.type === 'handler' && selectedComponent?.input?.options?.value) {\n  labelHandler = selectedComponent?.input?.options.value;\n} else if (selectedComponent?.input?.options?.type === 'array' && selectedComponent?.input?.options?.value) {\n  labelHandler = JSON.stringify(selectedComponent?.input?.options.value, null, 2);\n}\nreturn [parameter, labelHandler];",
        "eventHandlers": {
          "codeChange": "const selectedComponent = Utils.first($selectedComponents);\nif (EventData.value !== selectedComponent?.input?.options?.value) {\n  if(selectedComponent?.input?.options?.type != 'handler'){\n    updateInput(selectedComponent, 'options', selectedComponent?.input?.options?.type, JSON.parse(EventData.value));\n  }else{\n    updateInput(selectedComponent, 'options', 'handler', EventData.value);\n  }\n}"
        }
      },
      {
        "name": "dropdown_label",
        "label": "Label",
        "type": "text",
        "inputProperty": "label",
        "default": "Dropdown",
        "width": "180px",
        "placeholder": "Button label",
        "hasHandler": true,
        "handlerType": "input",
        "handlerProperty": "label",
        "valueHandler": {
          "ref": "componentInput",
          "params": ["label", "Dropdown"]
        },
        "stateHandler": {
          "ref": "inputHandler",
          "params": ["label"]
        },
        "eventHandlers": {
          "onChange": {
            "ref": "updateInput",
            "params": ["label", "value"]
          }
        }
      },
      {
        "name": "dropdown_placement",
        "label": "Placement",
        "type": "select",
        "inputProperty": "placement",
        "default": "bottom",
        "width": "180px",
        "placeholder": "Select placement",
        "options": [
          { "label": "Bottom", "value": "bottom" },
          { "label": "Bottom Start", "value": "bottom-start" },
          { "label": "Bottom End", "value": "bottom-end" },
          { "label": "Top", "value": "top" },
          { "label": "Top Start", "value": "top-start" },
          { "label": "Top End", "value": "top-end" }
        ],
        "hasHandler": false,
        "valueHandler": {
          "ref": "componentInput",
          "params": ["placement", "bottom"]
        },
        "eventHandlers": {
          "onChange": {
            "ref": "updateInput",
            "params": ["placement", "value"]
          }
        }
      },
      {
        "name": "dropdown_trigger",
        "label": "Trigger",
        "type": "select",
        "inputProperty": "trigger",
        "default": "click",
        "width": "180px",
        "placeholder": "Select trigger",
        "options": [
          { "label": "Click", "value": "click" },
          { "label": "Hover", "value": "hover" },
          { "label": "Focus", "value": "focus" },
          { "label": "Manual", "value": "manual" }
        ],
        "hasHandler": false,
        "valueHandler": {
          "ref": "componentInput",
          "params": ["trigger", "click"]
        },
        "eventHandlers": {
          "onChange": {
            "ref": "updateInput",
            "params": ["trigger", "value"]
          }
        }
      }
    ],
    "includeCommonProperties": [
      "component_value_text_block",
      "component_id_text_block",
      "display_block", "access_block",
      "component_hash_text_block"
    ],
    "includeContainers": []
  }
}
