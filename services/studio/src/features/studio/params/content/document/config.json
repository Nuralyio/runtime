{
  "documentFields": {
    "container": {
      "uuid": "document_collapse_container",
      "name": "Document Fields Container",
      "style": {}
    },
    "collapse": {
      "uuid": "document_collapse",
      "title": "Document Properties"
    },
    "properties": [
      {
        "name": "document_src",
        "label": "Source URL",
        "type": "text",
        "inputProperty": "src",
        "default": "",
        "width": "180px",
        "placeholder": "Document URL",
        "hasHandler": true,
        "handlerType": "input",
        "handlerProperty": "src",
        "valueHandler": {
          "ref": "componentInput",
          "params": ["src"]
        },
        "stateHandler": {
          "ref": "inputHandler",
          "params": ["src"]
        },
        "eventHandlers": {
          "onChange": {
            "ref": "updateInput",
            "params": ["src", "string"]
          }
        }
      },
      {
        "name": "document_type",
        "label": "Document Type",
        "type": "select",
        "inputProperty": "type",
        "default": "pdf",
        "width": "180px",
        "placeholder": "Select document type",
        "options": [
          { "label": "PDF", "value": "pdf" },
          { "label": "Image", "value": "image" },
          { "label": "Other", "value": "other" }
        ],
        "hasHandler": true,
        "handlerType": "input",
        "handlerProperty": "type",
        "valueHandler": {
          "ref": "componentInput",
          "params": ["type"]
        },
        "stateHandler": {
          "ref": "inputHandler",
          "params": ["type"]
        },
        "eventHandlers": {
          "onChange": {
            "ref": "updateInput",
            "params": ["type", "value"]
          }
        }
      },
      {
        "name": "document_previewable",
        "label": "Previewable",
        "type": "boolean",
        "inputProperty": "previewable",
        "default": false,
        "width": "180px",
        "hasHandler": true,
        "handlerType": "input",
        "handlerProperty": "previewable",
        "stateHandler": {
          "ref": "inputHandler",
          "params": ["previewable"]
        }
      }
    ],
    "includeCommonProperties": [
      "component_value_text_block",
      "component_id_text_block",
      "display_block",
      "component_hash_text_block"
    ],
    "includeContainers": []
  }
}
