{
  "richtextFields": {
    "container": {
      "uuid": "rich_text_collapse_container",
      "name": "Rich Text Fields Container",
      "style": {}
    },
    "collapse": {
      "uuid": "rich_text_collapse",
      "title": "Rich Text Properties"
    },
    "properties": [
      {
        "name": "richtext_value",
        "label": "Content",
        "type": "textarea",
        "inputProperty": "value",
        "default": "",
        "width": "180px",
        "placeholder": "Enter HTML content",
        "hasHandler": true,
        "handlerType": "input",
        "handlerProperty": "value",
        "valueHandler": {
          "ref": "componentInput",
          "params": ["value", ""]
        },
        "stateHandler": {
          "ref": "inputHandler",
          "params": ["value"]
        },
        "eventHandlers": {
          "onChange": {
            "ref": "updateInput",
            "params": ["value", "string"]
          }
        }
      }
    ],
    "includeCommonProperties": [
      "component_id_text_block"
    ],
    "includeContainers": []
  }
}
