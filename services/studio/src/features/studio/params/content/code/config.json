{
  "codeFields": {
    "container": {
      "uuid": "code_collapse_container",
      "name": "Code Fields Container",
      "style": {}
    },
    "collapse": {
      "uuid": "code_collapse",
      "title": "Code Properties"
    },
    "properties": [
      {
        "name": "code_value",
        "label": "Code Content",
        "type": "textarea",
        "inputProperty": "value",
        "default": "",
        "width": "180px",
        "placeholder": "Enter code...",
        "hasHandler": true,
        "handlerType": "input",
        "handlerProperty": "value",
        "valueHandler": {
          "ref": "componentInput",
          "params": ["value"]
        },
        "stateHandler": {
          "ref": "inputHandler",
          "params": ["value"]
        },
        "eventHandlers": {
          "onChange": {
            "ref": "updateInput",
            "params": ["value", "string"]
          }
        }
      },
      {
        "name": "language",
        "label": "Language",
        "type": "select",
        "inputProperty": "language",
        "default": "javascript",
        "width": "180px",
        "placeholder": "Select language",
        "options": [
          { "label": "JavaScript/TypeScript", "value": "javascript" },
          { "label": "HTML", "value": "html" },
          { "label": "CSS", "value": "css" },
          { "label": "JSON", "value": "json" },
          { "label": "Plain Text", "value": "plaintext" }
        ],
        "hasHandler": true,
        "handlerType": "input",
        "handlerProperty": "language",
        "valueHandler": {
          "ref": "componentInput",
          "params": ["language"]
        },
        "stateHandler": {
          "ref": "inputHandler",
          "params": ["language"]
        },
        "eventHandlers": {
          "onChange": {
            "ref": "updateInput",
            "params": ["language", "value"]
          }
        }
      },
      {
        "name": "theme",
        "label": "Theme",
        "type": "select",
        "inputProperty": "theme",
        "default": "vs-dark",
        "width": "180px",
        "placeholder": "Select theme",
        "options": [
          { "label": "Light (VS)", "value": "vs" },
          { "label": "Dark (VS Dark)", "value": "vs-dark" }
        ],
        "hasHandler": true,
        "handlerType": "input",
        "handlerProperty": "theme",
        "valueHandler": {
          "ref": "componentInput",
          "params": ["theme"]
        },
        "stateHandler": {
          "ref": "inputHandler",
          "params": ["theme"]
        },
        "eventHandlers": {
          "onChange": {
            "ref": "updateInput",
            "params": ["theme", "value"]
          }
        }
      },
      {
        "name": "code_readonly",
        "label": "Read Only",
        "type": "boolean",
        "inputProperty": "readonly",
        "default": false,
        "width": "180px",
        "hasHandler": true,
        "handlerType": "input",
        "handlerProperty": "readonly",
        "stateHandler": {
          "ref": "inputHandler",
          "params": ["readonly"]
        }
      }
    ],
    "includeCommonProperties": [
      "component_value_text_block",
      "component_id_text_block",
      "display_block", "access_block",
      "component_hash_text_block"
    ],
    "includeContainers": [
      "border_collapse_container"
    ]
  }
}
