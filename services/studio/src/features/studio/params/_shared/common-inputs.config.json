{
  "commonInputs": {
    "container": {
      "uuid": "text_label_collapse_container",
      "name": "Common Inputs Container",
      "style": {}
    },
    "collapse": {
      "uuid": "common_inputs_collapse",
      "title": "Component Settings",
      "style": {
        "--hy-collapse-content-small-size-padding": "5px",
        "--hy-collapse-font-weight": "normal",
        "--hy-collapse-border-radius": "0px",
        "--hy-collapse-width": "292px",
        "--hy-collapse-border": "none",
        "--hy-collapse-border-bottom": "1px solid #ccc",
        "--hy-collapse-local-header-background-color": "#3d3d3d"
      }
    },
    "properties": [
      {
        "name": "componentName",
        "label": "Name",
        "type": "text",
        "default": "",
        "width": "180px",
        "placeholder": "Component name",
        "valueHandler": { "ref": "componentName" },
        "stateHandler": { "ref": "valueHandler" },
        "eventHandlers": {
          "valueChange": { "ref": "updateName" }
        }
      },
      {
        "name": "componentId",
        "label": "ID",
        "type": "text",
        "default": "",
        "width": "180px",
        "placeholder": "id",
        "valueHandler": { "ref": "componentInput", "params": ["id"] },
        "stateHandler": { "ref": "inputHandler", "params": ["id"] },
        "eventHandlers": {
          "valueChange": { "ref": "updateInput", "params": ["id", "string"] }
        }
      },
      {
        "name": "componentValue",
        "label": "Value",
        "type": "text",
        "default": "",
        "width": "180px",
        "placeholder": "value",
        "valueHandler": { "ref": "componentInput", "params": ["value"] },
        "stateHandler": { "ref": "inputHandler", "params": ["value"] },
        "eventHandlers": {
          "valueChange": { "ref": "updateInput", "params": ["value", "string"] }
        }
      },
      {
        "name": "display",
        "label": "Display",
        "helperText": "Show or hide the component",
        "type": "radio",
        "default": true,
        "width": "80px",
        "valueHandler": { "ref": "displayToggle" },
        "eventHandlers": {
          "changed": "const selectedComponent = Utils.first($selectedComponents); if (selectedComponent) { updateInput(selectedComponent, 'display', 'string', EventData.value); }"
        }
      }
    ]
  }
}
