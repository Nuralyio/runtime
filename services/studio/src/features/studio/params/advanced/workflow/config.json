{
  "workflowFields": {
    "container": {
      "uuid": "workflow_collapse_container",
      "name": "Workflow Fields Container",
      "style": {}
    },
    "collapse": {
      "uuid": "workflow_collapse",
      "title": "Workflow Properties"
    },
    "properties": [
      {
        "name": "workflow_id",
        "label": "Workflow",
        "type": "select",
        "inputProperty": "workflowId",
        "default": "",
        "width": "180px",
        "placeholder": "Select workflow",
        "optionsHandler": "return (Vars.workflows || []).map(w => ({ label: w.name || w.id, value: w.id }));",
        "hasHandler": true,
        "handlerType": "input",
        "handlerProperty": "workflowId",
        "valueHandler": {
          "ref": "componentInput",
          "params": ["workflowId", ""]
        },
        "stateHandler": {
          "ref": "inputHandler",
          "params": ["workflowId"]
        },
        "eventHandlers": {
          "onChange": {
            "ref": "updateInput",
            "params": ["workflowId", "value"]
          }
        }
      },
      {
        "name": "workflow_trigger_type",
        "label": "Trigger Type",
        "type": "select",
        "inputProperty": "triggerType",
        "default": "manual",
        "width": "180px",
        "placeholder": "Select trigger",
        "options": [
          { "label": "Manual", "value": "manual" },
          { "label": "On Event", "value": "on_event" },
          { "label": "On Load", "value": "on_load" },
          { "label": "On Submit", "value": "on_submit" }
        ],
        "hasHandler": true,
        "handlerType": "input",
        "handlerProperty": "triggerType",
        "valueHandler": {
          "ref": "componentInput",
          "params": ["triggerType", "manual"]
        },
        "stateHandler": {
          "ref": "inputHandler",
          "params": ["triggerType"]
        },
        "eventHandlers": {
          "onChange": {
            "ref": "updateInput",
            "params": ["triggerType", "value"]
          }
        }
      },
      {
        "name": "workflow_auto_execute",
        "label": "Auto Execute",
        "type": "boolean",
        "inputProperty": "autoExecute",
        "default": false,
        "hasHandler": true,
        "handlerType": "input",
        "handlerProperty": "autoExecute",
        "valueHandler": {
          "ref": "componentInput",
          "params": ["autoExecute", false]
        },
        "stateHandler": {
          "ref": "inputHandler",
          "params": ["autoExecute"]
        }
      },
      {
        "name": "workflow_input_mapping",
        "label": "Input Mapping",
        "type": "textarea",
        "inputProperty": "inputMapping",
        "default": "{}",
        "width": "180px",
        "placeholder": "JSON input mapping",
        "hasHandler": true,
        "handlerType": "input",
        "handlerProperty": "inputMapping",
        "valueHandler": {
          "ref": "componentInput",
          "params": ["inputMapping", "{}"]
        },
        "stateHandler": {
          "ref": "inputHandler",
          "params": ["inputMapping"]
        },
        "eventHandlers": {
          "onChange": {
            "ref": "updateInput",
            "params": ["inputMapping", "value"]
          }
        }
      },
      {
        "name": "workflow_output_variable",
        "label": "Output Variable",
        "type": "text",
        "inputProperty": "outputVariable",
        "default": "",
        "width": "180px",
        "placeholder": "Variable name",
        "hasHandler": true,
        "handlerType": "input",
        "handlerProperty": "outputVariable",
        "valueHandler": {
          "ref": "componentInput",
          "params": ["outputVariable", ""]
        },
        "stateHandler": {
          "ref": "inputHandler",
          "params": ["outputVariable"]
        },
        "eventHandlers": {
          "onChange": {
            "ref": "updateInput",
            "params": ["outputVariable", "value"]
          }
        }
      },
      {
        "name": "workflow_show_status",
        "label": "Show Status",
        "type": "boolean",
        "inputProperty": "showStatus",
        "default": true,
        "hasHandler": true,
        "handlerType": "input",
        "handlerProperty": "showStatus",
        "valueHandler": {
          "ref": "componentInput",
          "params": ["showStatus", true]
        },
        "stateHandler": {
          "ref": "inputHandler",
          "params": ["showStatus"]
        }
      },
      {
        "name": "workflow_timeout",
        "label": "Timeout (ms)",
        "type": "number",
        "inputProperty": "timeout",
        "default": 30000,
        "width": "180px",
        "placeholder": "30000",
        "hasHandler": true,
        "handlerType": "input",
        "handlerProperty": "timeout",
        "valueHandler": {
          "ref": "componentInput",
          "params": ["timeout", 30000]
        },
        "stateHandler": {
          "ref": "inputHandler",
          "params": ["timeout"]
        },
        "eventHandlers": {
          "onChange": {
            "ref": "updateInput",
            "params": ["timeout", "value"]
          }
        }
      },
      {
        "name": "workflow_readonly",
        "label": "Read Only",
        "type": "boolean",
        "inputProperty": "readonly",
        "default": false,
        "hasHandler": true,
        "handlerType": "input",
        "handlerProperty": "readonly",
        "valueHandler": {
          "ref": "componentInput",
          "params": ["readonly", false]
        },
        "stateHandler": {
          "ref": "inputHandler",
          "params": ["readonly"]
        }
      },
      {
        "name": "workflow_execution_id",
        "label": "Execution ID",
        "type": "text",
        "inputProperty": "executionId",
        "default": "",
        "width": "180px",
        "placeholder": "{{chatbot_execution_id}}",
        "hasHandler": true,
        "handlerType": "input",
        "handlerProperty": "executionId",
        "valueHandler": {
          "ref": "componentInput",
          "params": ["executionId", ""]
        },
        "stateHandler": {
          "ref": "inputHandler",
          "params": ["executionId"]
        },
        "eventHandlers": {
          "onChange": {
            "ref": "updateInput",
            "params": ["executionId", "value"]
          }
        }
      }
    ],
    "includeCommonProperties": [
      "component_value_text_block",
      "component_id_text_block",
      "display_block",
      "access_block",
      "component_hash_text_block"
    ],
    "includeContainers": []
  }
}
