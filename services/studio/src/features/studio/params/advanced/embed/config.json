{
  "embedFields": {
    "container": {
      "uuid": "embed_collapse_container",
      "name": "Embed Fields Container",
      "style": {}
    },
    "collapse": {
      "uuid": "embed_collapse",
      "title": "Embed Properties"
    },
    "properties": [
      {
        "name": "url",
        "label": "URL",
        "type": "text",
        "inputProperty": "url",
        "default": "",
        "width": "180px",
        "placeholder": "https://nuraly.io",
        "hasHandler": true,
        "handlerType": "input",
        "handlerProperty": "url",
        "valueHandler": {
          "ref": "componentInput",
          "params": ["url"]
        },
        "stateHandler": {
          "ref": "inputHandler",
          "params": ["url"]
        },
        "eventHandlers": {
          "onChange": {
            "ref": "updateInput",
            "params": ["url", "string"]
          }
        }
      }
    ],
    "includeCommonProperties": [
      "component_value_text_block",
      "component_id_text_block",
      "display_block", "access_block",
      "component_hash_text_block"
    ],
    "includeContainers": []
  }
}
