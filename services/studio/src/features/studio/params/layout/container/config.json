{
  "containerFields": {
    "container": {
      "uuid": "container_collapse_container",
      "name": "Container Fields Container",
      "style": {}
    },
    "collapse": {
      "uuid": "container_collapse",
      "title": "Container Properties"
    },
    "properties": [
      {
        "name": "container_direction",
        "label": "Direction",
        "type": "select",
        "inputProperty": "direction",
        "default": "vertical",
        "width": "180px",
        "placeholder": "Select direction",
        "options": [
          { "label": "Vertical", "value": "vertical" },
          { "label": "Horizontal", "value": "horizontal" }
        ],
        "hasHandler": true,
        "handlerType": "input",
        "handlerProperty": "direction",
        "valueHandler": {
          "ref": "componentInput",
          "params": ["direction", "vertical"]
        },
        "stateHandler": {
          "ref": "inputHandler",
          "params": ["direction"]
        },
        "eventHandlers": {
          "onChange": {
            "ref": "updateInput",
            "params": ["direction", "value"]
          }
        }
      },
      {
        "name": "container_layout",
        "label": "Layout",
        "type": "select",
        "inputProperty": "layout",
        "default": "fluid",
        "width": "180px",
        "placeholder": "Select layout",
        "options": [
          { "label": "Fluid", "value": "fluid" },
          { "label": "Boxed", "value": "boxed" },
          { "label": "Fixed", "value": "fixed" }
        ],
        "hasHandler": true,
        "handlerType": "input",
        "handlerProperty": "layout",
        "valueHandler": {
          "ref": "componentInput",
          "params": ["layout", "fluid"]
        },
        "stateHandler": {
          "ref": "inputHandler",
          "params": ["layout"]
        },
        "eventHandlers": {
          "onChange": {
            "ref": "updateInput",
            "params": ["layout", "value"]
          }
        }
      },
      {
        "name": "container_justify",
        "label": "Justify",
        "type": "select",
        "inputProperty": "justify",
        "default": "",
        "width": "180px",
        "placeholder": "Select justify",
        "options": [
          { "label": "None", "value": "" },
          { "label": "Start", "value": "flex-start" },
          { "label": "Center", "value": "center" },
          { "label": "End", "value": "flex-end" },
          { "label": "Space Between", "value": "space-between" },
          { "label": "Space Around", "value": "space-around" },
          { "label": "Space Evenly", "value": "space-evenly" }
        ],
        "hasHandler": true,
        "handlerType": "input",
        "handlerProperty": "justify",
        "valueHandler": {
          "ref": "componentInput",
          "params": ["justify", ""]
        },
        "stateHandler": {
          "ref": "inputHandler",
          "params": ["justify"]
        },
        "eventHandlers": {
          "onChange": {
            "ref": "updateInput",
            "params": ["justify", "value"]
          }
        }
      },
      {
        "name": "container_align",
        "label": "Align",
        "type": "select",
        "inputProperty": "align",
        "default": "",
        "width": "180px",
        "placeholder": "Select align",
        "options": [
          { "label": "None", "value": "" },
          { "label": "Stretch", "value": "stretch" },
          { "label": "Start", "value": "flex-start" },
          { "label": "Center", "value": "center" },
          { "label": "End", "value": "flex-end" },
          { "label": "Baseline", "value": "baseline" }
        ],
        "hasHandler": true,
        "handlerType": "input",
        "handlerProperty": "align",
        "valueHandler": {
          "ref": "componentInput",
          "params": ["align", ""]
        },
        "stateHandler": {
          "ref": "inputHandler",
          "params": ["align"]
        },
        "eventHandlers": {
          "onChange": {
            "ref": "updateInput",
            "params": ["align", "value"]
          }
        }
      },
      {
        "name": "container_gap",
        "label": "Gap",
        "type": "text",
        "inputProperty": "gap",
        "default": "0",
        "width": "180px",
        "placeholder": "e.g. 10px or 10",
        "hasHandler": true,
        "handlerType": "input",
        "handlerProperty": "gap",
        "valueHandler": {
          "ref": "componentInput",
          "params": ["gap", "0"]
        },
        "stateHandler": {
          "ref": "inputHandler",
          "params": ["gap"]
        },
        "eventHandlers": {
          "onChange": {
            "ref": "updateInput",
            "params": ["gap", "value"]
          }
        }
      },
      {
        "name": "container_wrap",
        "label": "Wrap",
        "type": "checkbox",
        "inputProperty": "wrap",
        "default": false,
        "width": "180px",
        "hasHandler": true,
        "handlerType": "input",
        "handlerProperty": "wrap",
        "valueHandler": {
          "ref": "componentInput",
          "params": ["wrap", false]
        },
        "stateHandler": {
          "ref": "inputHandler",
          "params": ["wrap"]
        },
        "eventHandlers": {
          "onChange": {
            "ref": "updateInput",
            "params": ["wrap", "checked"]
          }
        }
      }
    ],
    "includeCommonProperties": [
      "component_value_text_block",
      "component_id_text_block",
      "display_block",
      "access_block",
      "component_hash_text_block"
    ],
    "includeContainers": []
  }
}
