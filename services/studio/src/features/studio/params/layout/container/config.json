{
  "containerFields": {
    "container": {
      "uuid": "container_collapse_container",
      "name": "Container Fields Container",
      "style": {}
    },
    "collapse": {
      "uuid": "container_collapse",
      "title": "Container Properties"
    },
    "properties": [
      {
        "name": "container_direction",
        "label": "Direction",
        "type": "select",
        "inputProperty": "direction",
        "default": "row",
        "width": "180px",
        "placeholder": "Select direction",
        "options": [
          { "label": "Row", "value": "row" },
          { "label": "Row Reverse", "value": "row-reverse" },
          { "label": "Column", "value": "column" },
          { "label": "Column Reverse", "value": "column-reverse" }
        ],
        "hasHandler": true,
        "handlerType": "input",
        "handlerProperty": "direction",
        "valueHandler": {
          "ref": "componentInput",
          "params": ["direction", "row"]
        },
        "stateHandler": {
          "ref": "inputHandler",
          "params": ["direction"]
        },
        "eventHandlers": {
          "onChange": {
            "ref": "updateInput",
            "params": ["direction", "value"]
          }
        }
      },
      {
        "name": "container_layout",
        "label": "Layout",
        "type": "select",
        "inputProperty": "layout",
        "default": "default",
        "width": "180px",
        "placeholder": "Select layout",
        "options": [
          { "label": "Default", "value": "default" },
          { "label": "Boxed", "value": "boxed" }
        ],
        "hasHandler": true,
        "handlerType": "input",
        "handlerProperty": "layout",
        "valueHandler": {
          "ref": "componentInput",
          "params": ["layout", "default"]
        },
        "stateHandler": {
          "ref": "inputHandler",
          "params": ["layout"]
        },
        "eventHandlers": {
          "onChange": {
            "ref": "updateInput",
            "params": ["layout", "value"]
          }
        }
      },
      {
        "name": "container_alignment",
        "label": "Alignment",
        "type": "select",
        "default": "flex-start",
        "width": "180px",
        "placeholder": "Select alignment",
        "options": [
          { "label": "Start", "value": "flex-start" },
          { "label": "Center", "value": "center" },
          { "label": "End", "value": "flex-end" },
          { "label": "Space Between", "value": "space-between" },
          { "label": "Space Around", "value": "space-around" },
          { "label": "Space Evenly", "value": "space-evenly" }
        ],
        "hasHandler": true,
        "handlerType": "style",
        "handlerProperty": "justify-content",
        "valueHandler": {
          "ref": "componentStyle",
          "params": ["justify-content", "flex-start"]
        },
        "stateHandler": {
          "ref": "defaultStyle",
          "params": ["justify-content"]
        },
        "eventHandlers": {
          "onChange": {
            "ref": "updateStyle",
            "params": ["justify-content"]
          }
        }
      },
      {
        "name": "container_align_items",
        "label": "Align Items",
        "type": "select",
        "default": "stretch",
        "width": "180px",
        "placeholder": "Select align items",
        "options": [
          { "label": "Stretch", "value": "stretch" },
          { "label": "Start", "value": "flex-start" },
          { "label": "Center", "value": "center" },
          { "label": "End", "value": "flex-end" },
          { "label": "Baseline", "value": "baseline" }
        ],
        "hasHandler": true,
        "handlerType": "style",
        "handlerProperty": "align-items",
        "valueHandler": {
          "ref": "componentStyle",
          "params": ["align-items", "stretch"]
        },
        "stateHandler": {
          "ref": "defaultStyle",
          "params": ["align-items"]
        },
        "eventHandlers": {
          "onChange": {
            "ref": "updateStyle",
            "params": ["align-items"]
          }
        }
      },
      {
        "name": "container_gap",
        "label": "Gap",
        "type": "text",
        "default": "0px",
        "width": "180px",
        "placeholder": "e.g. 10px",
        "hasHandler": true,
        "handlerType": "style",
        "handlerProperty": "gap",
        "valueHandler": {
          "ref": "componentStyle",
          "params": ["gap", "0px"]
        },
        "stateHandler": {
          "ref": "defaultStyle",
          "params": ["gap"]
        },
        "eventHandlers": {
          "onChange": {
            "ref": "updateStyle",
            "params": ["gap"]
          }
        }
      },
      {
        "name": "container_wrap",
        "label": "Wrap",
        "type": "select",
        "default": "nowrap",
        "width": "180px",
        "placeholder": "Select wrap",
        "options": [
          { "label": "No Wrap", "value": "nowrap" },
          { "label": "Wrap", "value": "wrap" },
          { "label": "Wrap Reverse", "value": "wrap-reverse" }
        ],
        "hasHandler": true,
        "handlerType": "style",
        "handlerProperty": "flex-wrap",
        "valueHandler": {
          "ref": "componentStyle",
          "params": ["flex-wrap", "nowrap"]
        },
        "stateHandler": {
          "ref": "defaultStyle",
          "params": ["flex-wrap"]
        },
        "eventHandlers": {
          "onChange": {
            "ref": "updateStyle",
            "params": ["flex-wrap"]
          }
        }
      }
    ],
    "includeCommonProperties": [
      "component_id_text_block"
    ],
    "includeContainers": []
  }
}
