{
  "containerFields": {
    "container": {
      "uuid": "grid_row_collapse_container",
      "name": "Grid Row Fields Container",
      "style": {}
    },
    "collapse": {
      "uuid": "grid_row_collapse",
      "title": "Grid Row Properties",
      "style": {
        "--hy-collapse-content-small-size-padding": "5px",
        "--hy-collapse-font-weight": "normal",
        "--hy-collapse-border-radius": "0px",
        "--hy-collapse-width": "292px",
        "--hy-collapse-border": "none",
        "--hy-collapse-border-bottom": "1px solid #ccc",
        "--hy-collapse-local-header-background-color": "#3d3d3d"
      }
    },
    "properties": [
      {
        "name": "gutter",
        "label": "Gutter (spacing)",
        "type": "number",
        "default": 0,
        "width": "153px",
        "valueHandler": { "ref": "componentInputNumber", "params": ["gutter", 0] },
        "stateHandler": { "ref": "inputHandler", "params": ["gutter"] },
        "eventHandlers": {
          "valueChange": { "ref": "updateInput", "params": ["gutter", "value"] }
        }
      },
      {
        "name": "align",
        "label": "Vertical Align",
        "type": "select",
        "default": "",
        "width": "180px",
        "placeholder": "Alignment",
        "options": [
          { "label": "None", "value": "" },
          { "label": "Top", "value": "top" },
          { "label": "Middle", "value": "middle" },
          { "label": "Bottom", "value": "bottom" },
          { "label": "Stretch", "value": "stretch" }
        ],
        "valueHandler": { "ref": "componentInputSelect", "params": ["align", ""] },
        "stateHandler": { "ref": "inputHandler", "params": ["align"] },
        "eventHandlers": {
          "changed": { "ref": "updateInput", "params": ["align", "value"] }
        }
      },
      {
        "name": "justify",
        "label": "Horizontal Align",
        "type": "select",
        "default": "",
        "width": "180px",
        "placeholder": "Justify",
        "options": [
          { "label": "None", "value": "" },
          { "label": "Start", "value": "start" },
          { "label": "End", "value": "end" },
          { "label": "Center", "value": "center" },
          { "label": "Space Around", "value": "space-around" },
          { "label": "Space Between", "value": "space-between" },
          { "label": "Space Evenly", "value": "space-evenly" }
        ],
        "valueHandler": { "ref": "componentInputSelect", "params": ["justify", ""] },
        "stateHandler": { "ref": "inputHandler", "params": ["justify"] },
        "eventHandlers": {
          "changed": { "ref": "updateInput", "params": ["justify", "value"] }
        }
      },
      {
        "name": "wrap",
        "label": "Wrap Columns",
        "type": "checkbox",
        "default": true,
        "width": "180px",
        "valueHandler": { "ref": "componentInputCheckbox", "params": ["wrap", true] },
        "stateHandler": { "ref": "inputHandler", "params": ["wrap"] },
        "eventHandlers": {
          "changed": { "ref": "updateInput", "params": ["wrap", "checked"] }
        }
      }
    ],
    "includeCommonProperties": [
      "component_value_text_block",
      "component_id_text_block",
      "display_block"
    ],
    "includeContainers": []
  }
}
