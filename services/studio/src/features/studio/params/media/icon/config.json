{
  "iconFields": {
    "container": {
      "uuid": "icon_collapse_container",
      "name": "Icon Fields Container",
      "style": {}
    },
    "collapse": {
      "uuid": "icon_collapse",
      "title": "Icon Properties"
    },
    "properties": [
      {
        "name": "icon",
        "label": "Icon Name",
        "type": "icon",
        "inputProperty": "name",
        "default": "smile",
        "width": "100%",
        "placeholder": "Choose an icon",
        "hasHandler": true,
        "handlerType": "input",
        "handlerProperty": "icon",
        "valueHandler": {
          "ref": "componentInput",
          "params": ["icon"]
        },
        "stateHandler": {
          "ref": "inputHandler",
          "params": ["icon"]
        },
        "eventHandlers": {
          "onChange": {
            "ref": "updateInput",
            "params": ["icon", "value"]
          }
        }
      },
      {
        "name": "type",
        "label": "Icon Type",
        "type": "radio",
        "inputProperty": "type",
        "default": "solid",
        "width": "180px",
        "options": [
          { "label": "Solid", "value": "solid" },
          { "label": "Regular", "value": "regular" }
        ],
        "hasHandler": true,
        "handlerType": "input",
        "handlerProperty": "type",
        "valueHandler": {
          "ref": "componentInput",
          "params": ["type"]
        },
        "stateHandler": {
          "ref": "inputHandler",
          "params": ["type"]
        },
        "eventHandlers": {
          "onChange": {
            "ref": "updateInput",
            "params": ["type", "value"]
          }
        }
      },
      {
        "name": "size",
        "label": "Size",
        "type": "select",
        "inputProperty": "size",
        "default": "medium",
        "width": "180px",
        "options": [
          { "label": "Small", "value": "small" },
          { "label": "Medium", "value": "medium" },
          { "label": "Large", "value": "large" },
          { "label": "X-Large", "value": "xlarge" },
          { "label": "XX-Large", "value": "xxlarge" }
        ],
        "hasHandler": true,
        "handlerType": "input",
        "handlerProperty": "size",
        "valueHandler": {
          "ref": "componentInput",
          "params": ["size"]
        },
        "stateHandler": {
          "ref": "inputHandler",
          "params": ["size"]
        },
        "eventHandlers": {
          "onChange": {
            "ref": "updateInput",
            "params": ["size", "value"]
          }
        }
      },
      {
        "name": "color",
        "label": "Icon Color",
        "type": "color",
        "inputProperty": "color",
        "default": "",
        "width": "180px",
        "hasHandler": true,
        "handlerType": "input",
        "handlerProperty": "color",
        "valueHandler": {
          "ref": "componentInput",
          "params": ["color"]
        },
        "stateHandler": {
          "ref": "inputHandler",
          "params": ["color"]
        },
        "eventHandlers": {
          "onChange": {
            "ref": "updateInput",
            "params": ["color", "value"]
          }
        }
      },
      {
        "name": "width",
        "label": "Width",
        "type": "text",
        "inputProperty": "width",
        "default": "",
        "width": "180px",
        "placeholder": "e.g., 24px, 2rem",
        "hasHandler": true,
        "handlerType": "input",
        "handlerProperty": "width",
        "valueHandler": {
          "ref": "componentInput",
          "params": ["width"]
        },
        "stateHandler": {
          "ref": "inputHandler",
          "params": ["width"]
        },
        "eventHandlers": {
          "onChange": {
            "ref": "updateInput",
            "params": ["width", "value"]
          }
        }
      },
      {
        "name": "height",
        "label": "Height",
        "type": "text",
        "inputProperty": "height",
        "default": "",
        "width": "180px",
        "placeholder": "e.g., 24px, 2rem",
        "hasHandler": true,
        "handlerType": "input",
        "handlerProperty": "height",
        "valueHandler": {
          "ref": "componentInput",
          "params": ["height"]
        },
        "stateHandler": {
          "ref": "inputHandler",
          "params": ["height"]
        },
        "eventHandlers": {
          "onChange": {
            "ref": "updateInput",
            "params": ["height", "value"]
          }
        }
      },
      {
        "name": "alt",
        "label": "Alt Text",
        "type": "text",
        "inputProperty": "alt",
        "default": "",
        "width": "180px",
        "placeholder": "Accessibility text",
        "hasHandler": true,
        "handlerType": "input",
        "handlerProperty": "alt",
        "valueHandler": {
          "ref": "componentInput",
          "params": ["alt"]
        },
        "stateHandler": {
          "ref": "inputHandler",
          "params": ["alt"]
        },
        "eventHandlers": {
          "onChange": {
            "ref": "updateInput",
            "params": ["alt", "value"]
          }
        }
      },
      {
        "name": "clickable",
        "label": "Clickable",
        "type": "boolean",
        "inputProperty": "clickable",
        "default": false,
        "width": "180px",
        "stateHandler": {
          "ref": "inputHandler",
          "params": ["clickable"]
        },
        "hasHandler": true,
        "handlerType": "input",
        "handlerProperty": "clickable"
      }
    ],
    "includeCommonProperties": [
      "component_value_text_block",
      "component_id_text_block",
      "display_block", "access_block",
      "component_hash_text_block"
    ],
    "includeContainers": []
  }
}
