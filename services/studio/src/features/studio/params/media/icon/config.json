{
  "iconFields": {
    "container": {
      "uuid": "icon_collapse_container",
      "name": "Icon Fields Container",
      "style": {}
    },
    "collapse": {
      "uuid": "icon_collapse",
      "title": "Icon Properties",
      "style": {
        "--hy-collapse-content-small-size-padding": "5px",
        "--hy-collapse-font-weight": "normal",
        "--hy-collapse-border-radius": "0px",
        "--hy-collapse-width": "292px",
        "--hy-collapse-border": "none",
        "--hy-collapse-border-bottom": "1px solid #ccc",
        "--hy-collapse-local-header-background-color": "#3d3d3d"
      }
    },
    "properties": [
      {
        "name": "name",
        "label": "Icon Name",
        "type": "icon",
        "default": "",
        "width": "100%",
        "placeholder": "Choose an icon",
        "valueHandler": {
          "ref": "componentInput",
          "params": ["name"]
        },
        "eventHandlers": {
          "iconChanged": {
            "ref": "updateInput",
            "params": ["name", "string"]
          }
        }
      },
      {
        "name": "size",
        "label": "Size",
        "type": "select",
        "default": "medium",
        "width": "100%",
        "options": [
          { "label": "Small", "value": "small" },
          { "label": "Medium", "value": "medium" },
          { "label": "Large", "value": "large" },
          { "label": "X-Large", "value": "xlarge" },
          { "label": "XX-Large", "value": "xxlarge" }
        ],
        "valueHandler": {
          "ref": "componentInput",
          "params": ["size"]
        },
        "stateHandler": {
          "ref": "inputHandler",
          "params": ["size"]
        },
        "eventHandlers": {
          "changed": {
            "ref": "updateInput",
            "params": ["size", "string"]
          }
        }
      },
      {
        "name": "color",
        "label": "Icon Color",
        "type": "color",
        "default": "",
        "width": "100%",
        "valueHandler": {
          "ref": "componentInput",
          "params": ["color"]
        },
        "stateHandler": {
          "ref": "inputHandler",
          "params": ["color"]
        },
        "eventHandlers": {
          "changed": {
            "ref": "updateInput",
            "params": ["color", "string"]
          }
        }
      },
      {
        "name": "width",
        "label": "Width",
        "type": "text",
        "default": "",
        "width": "100%",
        "placeholder": "e.g., 24px, 2rem",
        "valueHandler": {
          "ref": "componentInput",
          "params": ["width"]
        },
        "stateHandler": {
          "ref": "inputHandler",
          "params": ["width"]
        },
        "eventHandlers": {
          "valueChange": {
            "ref": "updateInput",
            "params": ["width", "value"]
          }
        }
      },
      {
        "name": "height",
        "label": "Height",
        "type": "text",
        "default": "",
        "width": "100%",
        "placeholder": "e.g., 24px, 2rem",
        "valueHandler": {
          "ref": "componentInput",
          "params": ["height"]
        },
        "stateHandler": {
          "ref": "inputHandler",
          "params": ["height"]
        },
        "eventHandlers": {
          "valueChange": {
            "ref": "updateInput",
            "params": ["height", "value"]
          }
        }
      },
      {
        "name": "alt",
        "label": "Alt Text",
        "type": "text",
        "default": "",
        "width": "100%",
        "placeholder": "Accessibility text",
        "valueHandler": {
          "ref": "componentInput",
          "params": ["alt"]
        },
        "stateHandler": {
          "ref": "inputHandler",
          "params": ["alt"]
        },
        "eventHandlers": {
          "valueChange": {
            "ref": "updateInput",
            "params": ["alt", "value"]
          }
        }
      }
    ],
    "includeCommonProperties": [
      "component_value_text_block",
      "display_block",
      "component_id_text_block"
    ],
    "includeContainers": []
  }
}
