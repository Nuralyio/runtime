{
  "videoFields": {
    "container": {
      "uuid": "video_collapse_container",
      "name": "Video Fields Container",
      "style": {}
    },
    "collapse": {
      "uuid": "video_collapse",
      "title": "Video Properties"
    },
    "properties": [
      {
        "name": "src",
        "label": "Source URL",
        "type": "text",
        "inputProperty": "src",
        "default": "",
        "width": "180px",
        "placeholder": "Video URL",
        "hasHandler": true,
        "handlerType": "input",
        "handlerProperty": "src",
        "valueHandler": {
          "ref": "componentInput",
          "params": ["src"]
        },
        "stateHandler": {
          "ref": "inputHandler",
          "params": ["src"]
        },
        "eventHandlers": {
          "onChange": {
            "ref": "updateInput",
            "params": ["src", "string"]
          }
        }
      },
      {
        "name": "poster",
        "label": "Poster Image",
        "type": "text",
        "inputProperty": "poster",
        "default": "",
        "width": "180px",
        "placeholder": "Poster image URL",
        "hasHandler": true,
        "handlerType": "input",
        "handlerProperty": "poster",
        "valueHandler": {
          "ref": "componentInput",
          "params": ["poster"]
        },
        "stateHandler": {
          "ref": "inputHandler",
          "params": ["poster"]
        },
        "eventHandlers": {
          "onChange": {
            "ref": "updateInput",
            "params": ["poster", "string"]
          }
        }
      },
      {
        "name": "preload",
        "label": "Preload",
        "type": "select",
        "inputProperty": "preload",
        "default": "metadata",
        "width": "180px",
        "placeholder": "Select preload mode",
        "options": [
          { "label": "None", "value": "none" },
          { "label": "Metadata", "value": "metadata" },
          { "label": "Auto", "value": "auto" }
        ],
        "hasHandler": true,
        "handlerType": "input",
        "handlerProperty": "preload",
        "valueHandler": {
          "ref": "componentInput",
          "params": ["preload"]
        },
        "stateHandler": {
          "ref": "inputHandler",
          "params": ["preload"]
        },
        "eventHandlers": {
          "onChange": {
            "ref": "updateInput",
            "params": ["preload", "value"]
          }
        }
      },
      {
        "name": "autoplay",
        "label": "Autoplay",
        "type": "boolean",
        "inputProperty": "autoplay",
        "default": false,
        "width": "180px",
        "hasHandler": true,
        "handlerType": "input",
        "handlerProperty": "autoplay",
        "stateHandler": {
          "ref": "inputHandler",
          "params": ["autoplay"]
        }
      },
      {
        "name": "controls",
        "label": "Show Controls",
        "type": "boolean",
        "inputProperty": "controls",
        "default": true,
        "width": "180px",
        "hasHandler": true,
        "handlerType": "input",
        "handlerProperty": "controls",
        "stateHandler": {
          "ref": "inputHandler",
          "params": ["controls"]
        }
      },
      {
        "name": "loop",
        "label": "Loop",
        "type": "boolean",
        "inputProperty": "loop",
        "default": false,
        "width": "180px",
        "hasHandler": true,
        "handlerType": "input",
        "handlerProperty": "loop",
        "stateHandler": {
          "ref": "inputHandler",
          "params": ["loop"]
        }
      },
      {
        "name": "muted",
        "label": "Muted",
        "type": "boolean",
        "inputProperty": "muted",
        "default": false,
        "width": "180px",
        "hasHandler": true,
        "handlerType": "input",
        "handlerProperty": "muted",
        "stateHandler": {
          "ref": "inputHandler",
          "params": ["muted"]
        }
      }
    ],
    "includeCommonProperties": [
      "component_value_text_block",
      "component_id_text_block",
      "display_block",
      "component_hash_text_block"
    ],
    "includeContainers": []
  }
}
