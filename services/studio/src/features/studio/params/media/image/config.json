{
  "imageFields": {
    "container": {
      "uuid": "image_input_collapse_container",
      "name": "Image Fields Container",
      "style": {}
    },
    "collapse": {
      "uuid": "image_input_collapse",
      "title": "Image Properties"
    },
    "properties": [
      {
        "name": "src",
        "label": "Source URL",
        "type": "text",
        "inputProperty": "src",
        "default": "",
        "width": "180px",
        "placeholder": "Image URL",
        "hasHandler": true,
        "handlerType": "input",
        "handlerProperty": "src",
        "valueHandler": {
          "ref": "componentInput",
          "params": ["src"]
        },
        "stateHandler": {
          "ref": "inputHandler",
          "params": ["src"]
        },
        "eventHandlers": {
          "onChange": {
            "ref": "updateInput",
            "params": ["src", "string"]
          }
        }
      },
      {
        "name": "darkSrc",
        "label": "Dark Mode URL",
        "type": "text",
        "inputProperty": "darkSrc",
        "default": "",
        "width": "180px",
        "placeholder": "Dark mode image URL",
        "hasHandler": true,
        "handlerType": "input",
        "handlerProperty": "darkSrc",
        "valueHandler": {
          "ref": "componentInput",
          "params": ["darkSrc"]
        },
        "stateHandler": {
          "ref": "inputHandler",
          "params": ["darkSrc"]
        },
        "eventHandlers": {
          "onChange": {
            "ref": "updateInput",
            "params": ["darkSrc", "string"]
          }
        }
      },
      {
        "name": "alt",
        "label": "Alt Text",
        "type": "text",
        "inputProperty": "alt",
        "default": "",
        "width": "180px",
        "placeholder": "Image description",
        "hasHandler": true,
        "handlerType": "input",
        "handlerProperty": "alt",
        "valueHandler": {
          "ref": "componentInput",
          "params": ["alt"]
        },
        "stateHandler": {
          "ref": "inputHandler",
          "params": ["alt"]
        },
        "eventHandlers": {
          "onChange": {
            "ref": "updateInput",
            "params": ["alt", "string"]
          }
        }
      },
      {
        "name": "fallback",
        "label": "Fallback URL",
        "type": "text",
        "inputProperty": "fallback",
        "default": "",
        "width": "180px",
        "placeholder": "Fallback image URL",
        "hasHandler": true,
        "handlerType": "input",
        "handlerProperty": "fallback",
        "valueHandler": {
          "ref": "componentInput",
          "params": ["fallback"]
        },
        "stateHandler": {
          "ref": "inputHandler",
          "params": ["fallback"]
        },
        "eventHandlers": {
          "onChange": {
            "ref": "updateInput",
            "params": ["fallback", "string"]
          }
        }
      },
      {
        "name": "fit",
        "label": "Object Fit",
        "type": "select",
        "inputProperty": "fit",
        "default": "cover",
        "width": "180px",
        "placeholder": "Select fit mode",
        "options": [
          { "label": "None", "value": "none" },
          { "label": "Fill", "value": "fill" },
          { "label": "Contain", "value": "contain" },
          { "label": "Cover", "value": "cover" },
          { "label": "Scale Down", "value": "scale-down" }
        ],
        "hasHandler": true,
        "handlerType": "input",
        "handlerProperty": "fit",
        "valueHandler": {
          "ref": "componentInput",
          "params": ["fit"]
        },
        "stateHandler": {
          "ref": "inputHandler",
          "params": ["fit"]
        },
        "eventHandlers": {
          "onChange": {
            "ref": "updateInput",
            "params": ["fit", "value"]
          }
        }
      },
      {
        "name": "previewable",
        "label": "Previewable",
        "type": "boolean",
        "inputProperty": "previewable",
        "default": false,
        "width": "180px",
        "hasHandler": true,
        "handlerType": "input",
        "handlerProperty": "previewable",
        "stateHandler": {
          "ref": "inputHandler",
          "params": ["previewable"]
        }
      },
      {
        "name": "block",
        "label": "Block Display",
        "type": "boolean",
        "inputProperty": "block",
        "default": false,
        "width": "180px",
        "hasHandler": true,
        "handlerType": "input",
        "handlerProperty": "block",
        "stateHandler": {
          "ref": "inputHandler",
          "params": ["block"]
        }
      }
    ],
    "includeCommonProperties": [
      "component_value_text_block",
      "component_id_text_block",
      "display_block",
      "component_hash_text_block"
    ],
    "includeContainers": []
  }
}
