{
  "iconFields": {
    "container": {
      "uuid": "icon_collapse_container",
      "name": "Icon Fields Container",
      "style": {}
    },
    "collapse": {
      "uuid": "icon_collapse",
      "title": "Icon Properties",
      "style": {
        "--hy-collapse-content-small-size-padding": "5px",
        "--hy-collapse-font-weight": "normal",
        "--hy-collapse-border-radius": "0px",
        "--hy-collapse-width": "292px",
        "--hy-collapse-border": "none",
        "--hy-collapse-border-bottom": "1px solid #ccc",
        "--hy-collapse-local-header-background-color": "#3d3d3d"
      }
    },
    "properties": [
      {
        "name": "icon",
        "label": "Icon",
        "type": "icon",
        "default": "",
        "width": "100%",
        "placeholder": "Choose an icon",
        "valueHandler": {
          "ref": "componentInput",
          "params": ["icon"]
        },
        "eventHandlers": {
          "iconChanged": {
            "ref": "updateInput",
            "params": ["icon", "string"]
          }
        }
      },
      {
        "name": "iconColor",
        "label": "Icon Color",
        "type": "color",
        "default": "",
        "width": "100%",
        "valueHandler": {
          "ref": "componentStyleSelect",
          "params": ["--hybrid-icon-color"]
        },
        "stateHandler": {
          "ref": "componentStyleSelect",
          "params": ["--hybrid-icon-color"]
        },
        "eventHandlers": {
          "colorChange": {
            "ref": "componentStyleSelect",
            "params": ["--hybrid-icon-color", "EventData.value"]
          }
        }
      }
    ],
    "includeCommonProperties": [
      "component_value_text_block",
      "display_block",
      "component_id_text_block"
    ],
    "includeContainers": []
  }
}
