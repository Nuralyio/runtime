---
/**
 * HomeHeader Component
 * Clean header like baseten
 */
---

<header class="home-header" style="background: #f8fafc;">
  <div class="container">
    <div class="home-header-inner">
      <a href="/" class="home-logo">
        <span class="logo-text">Nuraly</span>
        <span class="logo-slogan">The Agentic platform</span>
      </a>

      <nav class="home-nav">
        <div class="home-nav-links">
          <a href="/features" class="home-nav-link">Features</a>
          <a href="/docs" class="home-nav-link">Docs</a>
          <a href="/pricing" class="home-nav-link">Pricing</a>
        </div>

        <div class="home-nav-actions">
          <a href="/login" class="btn btn-secondary">LOG IN</a>
          <a href="/signup" class="btn btn-primary">GET STARTED</a>
        </div>
      </nav>
    </div>
  </div>
</header>

<style>
  .home-logo {
    margin-left: 21px;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 2px;
  }

  .logo-text {
    font-size: 24px;
    font-weight: 700;
    color: #0f0f3c;
    letter-spacing: -0.02em;
    line-height: 1;
  }

  .logo-slogan {
    font-size: 11px;
    color: #6b7280;
    letter-spacing: 0.02em;
  }
</style>
