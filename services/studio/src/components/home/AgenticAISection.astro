---
/**
 * AgenticAISection Component
 * Dedicated section showcasing AI/Agentic capabilities
 */

const capabilities = [
  {
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
      <rect x="3" y="3" width="18" height="18" rx="2"/>
      <circle cx="12" cy="10" r="3"/>
      <path d="M8 17v-1a4 4 0 0 1 8 0v1"/>
    </svg>`,
    title: "Autonomous AI Agents",
    description: "Connect to any LLM provider — OpenAI, Anthropic, Gemini, or self-hosted Ollama. Build agents that reason, plan, and execute."
  },
  {
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
      <path d="M12 2L2 7l10 5 10-5-10-5z"/>
      <path d="M2 17l10 5 10-5M2 12l10 5 10-5"/>
    </svg>`,
    title: "Visual Workflow Orchestration",
    description: "Conditions, loops, parallel execution, and human-in-the-loop. Design complex agent behaviors without writing code."
  },
  {
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
      <ellipse cx="12" cy="6" rx="8" ry="3"/>
      <path d="M4 6v6c0 1.66 3.58 3 8 3s8-1.34 8-3V6"/>
      <path d="M4 12v6c0 1.66 3.58 3 8 3s8-1.34 8-3v-6"/>
    </svg>`,
    title: "Context Memory & RAG",
    description: "Persistent memory, vector stores, and retrieval-augmented generation. Give your agents long-term context awareness."
  },
  {
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
      <path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/>
    </svg>`,
    title: "Tool-Calling Agents",
    description: "Invoke functions, APIs, and databases autonomously. Agents that can take real-world actions on your behalf."
  }
];
---

<section class="agentic-ai">
  <div class="container">
    <div class="agentic-header" data-animate>
      <p class="section-label">AI-First Platform</p>
      <h2>Enterprise-grade AI Agents, built visually</h2>
      <p class="agentic-subtitle">
        From simple chatbots to complex multi-step reasoning agents. Deploy production AI in minutes, not months.
      </p>
    </div>

    <div class="agentic-grid" data-animate>
      {capabilities.map((cap) => (
        <div class="agentic-card">
          <div class="agentic-icon" set:html={cap.icon} />
          <h3>{cap.title}</h3>
          <p>{cap.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .agentic-ai {
    padding: 100px 0;
    background: linear-gradient(180deg, var(--color-bg) 0%, var(--color-bg-secondary) 100%);
    border-top: 1px solid var(--color-border);
  }

  .agentic-header {
    text-align: center;
    margin-bottom: 64px;
  }

  .agentic-header h2 {
    font-size: 36px;
    font-weight: 600;
    letter-spacing: -0.02em;
    color: var(--color-text);
    margin-bottom: 16px;
  }

  .agentic-subtitle {
    font-size: 18px;
    color: var(--color-text-secondary);
    max-width: 600px;
    margin: 0 auto;
    line-height: 1.6;
  }

  .agentic-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 24px;
  }

  .agentic-card {
    background: #ffffff;
    padding: 32px;
    border-radius: 12px;
    border: 1px solid var(--color-border);
    transition: all var(--transition);
  }

  .agentic-card:hover {
    border-color: var(--color-primary);
    box-shadow: 0 4px 24px rgba(20, 20, 75, 0.08);
    transform: translateY(-2px);
  }

  .agentic-icon {
    width: 48px;
    height: 48px;
    margin-bottom: 20px;
    color: var(--color-primary);
    background: var(--color-primary-bg);
    padding: 12px;
    border-radius: 10px;
  }

  .agentic-card h3 {
    font-size: 20px;
    font-weight: 600;
    margin-bottom: 12px;
    letter-spacing: -0.01em;
    color: var(--color-text);
  }

  .agentic-card p {
    font-size: 15px;
    color: var(--color-text-secondary);
    line-height: 1.6;
  }

  @media (max-width: 768px) {
    .agentic-ai {
      padding: 60px 0;
    }

    .agentic-header h2 {
      font-size: 28px;
    }

    .agentic-grid {
      grid-template-columns: 1fr;
      gap: 16px;
    }

    .agentic-card {
      padding: 24px;
    }
  }
</style>
