---
/**
 * FeatureCards Component
 * Minimal feature grid with dashed borders
 */

const features = [
  {
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
      <rect x="3" y="3" width="18" height="18" rx="2"/>
      <path d="M3 9h18M9 21V9"/>
    </svg>`,
    title: "Visual Editor",
    description: "Drag-and-drop interface builder. Design responsive layouts without writing CSS."
  },
  {
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
      <path d="M12 2L2 7l10 5 10-5-10-5z"/>
      <path d="M2 17l10 5 10-5M2 12l10 5 10-5"/>
    </svg>`,
    title: "AI Copilot",
    description: "Describe what you want. AI generates components, layouts, and logic for you."
  },
  {
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
      <polyline points="16 18 22 12 16 6"/>
      <polyline points="8 6 2 12 8 18"/>
    </svg>`,
    title: "Serverless Functions",
    description: "Write backend logic in JavaScript. Deploy instantly, scale automatically."
  }
];
---

<section class="features">
  <div class="container">
    <div class="features-header" data-animate>
      <p class="section-label">Capabilities</p>
      <h2>Everything you need to ship</h2>
    </div>

    <div class="feature-grid" data-animate>
      {features.map((feature) => (
        <div class="feature-card">
          <div class="feature-icon" set:html={feature.icon} />
          <h3>{feature.title}</h3>
          <p>{feature.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
