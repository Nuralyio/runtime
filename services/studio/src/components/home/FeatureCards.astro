---
/**
 * FeatureCards Component
 * Minimal feature grid with dashed borders
 */

const features = [
  {
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
      <rect x="3" y="3" width="18" height="18" rx="2"/>
      <circle cx="12" cy="10" r="3"/>
      <path d="M8 17v-1a4 4 0 0 1 8 0v1"/>
    </svg>`,
    title: "AI Agents & LLMs",
    description: "Deploy autonomous AI agents powered by any LLM. Connect OpenAI, Anthropic, Gemini, or self-hosted models."
  },
  {
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
      <path d="M12 2L2 7l10 5 10-5-10-5z"/>
      <path d="M2 17l10 5 10-5M2 12l10 5 10-5"/>
    </svg>`,
    title: "Visual Workflow Engine",
    description: "Design complex automations visually with drag-and-drop. Conditions, loops, parallel execution built-in."
  },
  {
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
      <polyline points="16 18 22 12 16 6"/>
      <polyline points="8 6 2 12 8 18"/>
    </svg>`,
    title: "Serverless Functions",
    description: "Write backend logic in JavaScript. Deploy instantly with Docker, scale automatically."
  },
  {
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
      <rect x="3" y="3" width="18" height="18" rx="2"/>
      <path d="M7 7h4v4H7zM13 7h4M13 11h4M7 15h10"/>
    </svg>`,
    title: "Document AI (TextLens)",
    description: "Extract text from images and documents with built-in OCR. Process PDFs, receipts, and handwritten notes."
  },
  {
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
      <rect x="3" y="3" width="18" height="18" rx="2"/>
      <path d="M3 9h18M9 21V9"/>
    </svg>`,
    title: "Visual Interface Builder",
    description: "Drag-and-drop UI design. Build responsive layouts and connect them to your workflows without writing CSS."
  },
  {
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
      <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
      <circle cx="9" cy="10" r="1" fill="currentColor"/>
      <circle cx="12" cy="10" r="1" fill="currentColor"/>
      <circle cx="15" cy="10" r="1" fill="currentColor"/>
    </svg>`,
    title: "Embeddable Chatbots",
    description: "Deploy AI chatbots anywhere with WebSocket streaming. Embed in websites, apps, or internal tools."
  }
];
---

<section class="features" id="features">
  <div class="container">
    <div class="features-header" data-animate>
      <p class="section-label">Capabilities</p>
      <h2>Everything you need for production AI</h2>
    </div>

    <div class="feature-grid" data-animate>
      {features.map((feature) => (
        <div class="feature-card">
          <div class="feature-icon" set:html={feature.icon} />
          <h3>{feature.title}</h3>
          <p>{feature.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
