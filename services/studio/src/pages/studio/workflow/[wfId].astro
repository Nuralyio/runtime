---
/**
 * Standalone Workflow Studio Route
 * /studio/workflow/{wfId}
 * Full workflow editor for standalone workflows (not linked to an app)
 */
export const prerender = false;

import { processHeaders } from '../../../features/runtime/utils/api-calls-utils';
import { workflowService } from '../../../services/workflow.service';

const { wfId } = Astro.params;

// Fetch workflow data
let workflow = null;
let error = null;

try {
  const processedHeaders = processHeaders(Astro.request.headers);
  workflow = await workflowService.getWorkflow(wfId);
} catch (e) {
  console.error('Failed to fetch workflow:', e);
  error = e instanceof Error ? e.message : 'Failed to load workflow';
}
---

<!doctype html>
<html lang="en" data-theme="default-light">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{workflow?.name || 'Workflow'} - Nuraly Studio</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@nuralyui/themes@latest/dist/default.css">
    <style>
      :root {
        --nuraly-color-primary: #14144b;
        --nuraly-color-primary-light: #1e1e6e;
        --nuraly-color-primary-dark: #0a0a32;
        --nuraly-color-bg: #f8fafc;
        --nuraly-color-background: #f8fafc;
        --nuraly-color-surface: #ffffff;
        --nuraly-color-text: #0f0f3c;
        --nuraly-color-text-secondary: #5c5c7a;
        --nuraly-color-border: #e8e8f0;
      }

      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }

      body {
        font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif;
        background: var(--nuraly-color-background);
        color: var(--nuraly-color-text);
        min-height: 100vh;
      }

      .studio-layout {
        display: flex;
        flex-direction: column;
        min-height: 100vh;
      }

      .studio-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 12px 24px;
        background: var(--nuraly-color-surface);
        border-bottom: 1px solid var(--nuraly-color-border);
      }

      .header-left {
        display: flex;
        align-items: center;
        gap: 16px;
      }

      .back-link {
        display: flex;
        align-items: center;
        gap: 8px;
        color: var(--nuraly-color-text-secondary);
        text-decoration: none;
        font-size: 14px;
        transition: color 150ms ease;
      }

      .back-link:hover {
        color: var(--nuraly-color-text);
      }

      .workflow-title {
        font-size: 18px;
        font-weight: 600;
        color: var(--nuraly-color-text);
      }

      .standalone-badge {
        display: inline-flex;
        align-items: center;
        padding: 4px 10px;
        background: var(--nuraly-color-primary-light);
        color: white;
        font-size: 11px;
        font-weight: 500;
        border-radius: 4px;
        text-transform: uppercase;
        letter-spacing: 0.5px;
      }

      .studio-content {
        flex: 1;
        display: flex;
        flex-direction: column;
      }

      .error-container {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        padding: 80px 24px;
        text-align: center;
      }

      .error-title {
        font-size: 24px;
        font-weight: 600;
        margin-bottom: 12px;
      }

      .error-message {
        color: var(--nuraly-color-text-secondary);
        margin-bottom: 24px;
      }

      standalone-workflow-editor {
        display: block;
        flex: 1;
        min-height: 0;
      }
    </style>
  </head>
  <body>
    <div class="studio-layout">
      <header class="studio-header">
        <div class="header-left">
          <a href="/dashboard" class="back-link">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M19 12H5M12 19l-7-7 7-7"/>
            </svg>
            Dashboard
          </a>
          {workflow && (
            <>
              <span class="workflow-title">{workflow.name}</span>
              <span class="standalone-badge">Standalone</span>
            </>
          )}
        </div>
        <div class="header-right">
          <!-- Actions can be added here -->
        </div>
      </header>

      <div class="studio-content">
        {error ? (
          <div class="error-container">
            <h2 class="error-title">Unable to load workflow</h2>
            <p class="error-message">{error}</p>
            <a href="/dashboard" class="back-link">Return to Dashboard</a>
          </div>
        ) : (
          <standalone-workflow-editor workflow-id={wfId}></standalone-workflow-editor>
        )}
      </div>
    </div>

    <script is:inline define:vars={{ workflow, wfId }}>
      window.__STANDALONE_WORKFLOW__ = workflow;
      window.__STANDALONE_WORKFLOW_ID__ = wfId;
    </script>

    <script>
      import "../../../features/dashboard";
      import "../../../features/runtime/components";
    </script>
  </body>
</html>
