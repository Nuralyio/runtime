---
import MakeLayout from "../layouts/MakeLayout.astro";
import "../components/pages/studio/MainPanel/EditorInteractivePanel";
import { TabsPanel } from "../components/pages/studio/MainPanel/TabsPanel";
import "@hybridui/button";
import { TopbarPanelWrapper } from "../components/pages/studio/TopBar/TopbarWrapper/TopbarWrapper";
import { LeftPanel } from "../components/pages/studio/Layout/LeftPanel";
import { RightPanel } from "../components/pages/studio/Layout/RightPanel";
import { $pages, $resetPageStore } from "../store/page/store";
import { allTasks } from "nanostores";
import { $components } from "$store/component/sotre";
import { $applications } from "$store/apps";
import { serviceWorkerReadyCallback } from "core/engine";
const _serviceWorkerReadyCallback = serviceWorkerReadyCallback;
const cookie = Astro.request.headers.get("Cookie");
const headers = {};
Astro.request.headers.forEach((value, key) => {
  headers[key] = value;
});
const { app } = Astro.props;

delete headers["connection"];
const pageResponse = await fetch(
  `http://${process.env.NURALY_SERVICES_HOST || "localhost"}/api/pages/${app.uuid}`,
  {
    headers: {
      ...headers,
      Cookie: cookie,
    },
  },
);

const pageData = await pageResponse.json();
$pages.set(pageData);

const componentResponse = await fetch(
  `http://${process.env.NURALY_SERVICES_HOST || "localhost"}/api/components/${app.uuid}`,
  {
    headers: {
      ...headers,
      Cookie: cookie,
    },
  },
);

let componentData = await componentResponse.json();

componentData = componentData.map((component) => {
  return component.component;
});
const applciationsResponse = await fetch(
  `http://${process.env.NURALY_SERVICES_HOST || "localhost"}/api/applications`,
  {
    headers: {
      ...headers,
      Cookie: cookie,
    },
  },
);

const applications = await applciationsResponse.json();
$applications.set(applications);
const application = applications.find(
  (application) => application.uuid === app.uuid,
);

$components.set({
  [application.uuid]: componentData,
});
console.log($components.get());
// $resetPageStore()
---

<head> <title>Nuraly - Editing {app.name}</title> </head>

<MakeLayout title="Make Apps">
  <div class="H-full flex flex-wrap mx-auto" style=" 
">
    <TopbarPanelWrapper client:load>
      <div
        class="border border-blue-300 shadow rounded-md p-4 m-4"
        style="width :98vw; margin-top: 4%;"
      >
        <div class="animate-pulse flex space-x-4">
          <div class="flex-1 space-y-6 py-1">
            <div class="space-y-3">
              <div class="grid grid-cols-3 gap-4">
                <div class="h-2 bg-slate-500 rounded col-span-2"></div>
                <div class="h-2 bg-slate-500 rounded col-span-1"></div>
              </div>
              <div class="h-2 bg-slate-500 rounded"></div>
            </div>
          </div>
        </div>
      </div>
      <div
        class="border border-blue-300 shadow rounded-md p-4 m-4"
        style="width :98vw; "
      >
        <div class="animate-pulse flex space-x-4">
          <div class="flex-1 space-y-6 py-1">
            <div class="space-y-3">
              <div class="grid grid-cols-3 gap-4">
                <div class="h-2 bg-slate-500 rounded col-span-2"></div>
                <div class="h-2 bg-slate-500 rounded col-span-1"></div>
              </div>
              <div class="h-2 bg-slate-500 rounded"></div>
            </div>
          </div>
        </div>
      </div>
      <div
        class="border border-blue-300 shadow rounded-md p-4 m-4"
        style="width :98vw; "
      >
        <div class="animate-pulse flex space-x-4">
          <div class="flex-1 space-y-6 py-1">
            <div class="space-y-3">
              <div class="grid grid-cols-3 gap-4">
                <div class="h-2 bg-slate-500 rounded col-span-2"></div>
                <div class="h-2 bg-slate-500 rounded col-span-1"></div>
              </div>
              <div class="h-2 bg-slate-500 rounded"></div>
            </div>
          </div>
        </div>
      </div>
    </TopbarPanelWrapper>
  </div>
  <div class="flex flex-row text-gray-800">
    <LeftPanel client:load />
    <main
      class="main flex flex-grow flex-col transition-all duration-150 ease-in md:ml-0"
    >
      <TabsPanel client:only="lit" />
    </main>
    <RightPanel client:only="lit" />
  </div>
</MakeLayout>
<script define:vars={{ pageData, componentData, applications, application }}>
  window.__INITIAL_PAGE_STATE__ = JSON.stringify(pageData);
  window.__INITIAL_COMPONENT_STATE__ = JSON.stringify(componentData);
  window.__INITIAL_APPLICATION_STATE__ = JSON.stringify(applications);
  window.__INITIAL_CURRENT_APPLICATION_STATE__ = JSON.stringify(application);

  if ('serviceWorker' in navigator) {
    window.addEventListener('load', function () {
        navigator.serviceWorker.register('/custom-sw.js')
            .then(function (registration) {
                // Service worker registered successfully
                navigator.serviceWorker.ready.then(function (registration) {
                    registration.active.postMessage({ type: 'CHECK_SERVICE_WORKER' });

                    // Add message event listener
                    navigator.serviceWorker.addEventListener('message', function(event) {
                        if (event.data && event.data.type === 'SERVICE_WORKER_READY') {
                            console.log('Service Worker is ready');
                            document.dispatchEvent(new CustomEvent("serviceWorkerReady"));

                        }
                    });
                });
            })
            .catch(function (registrationError) {
                console.log('Service Worker registration failed:', registrationError);
            });
    });
}
</script>
<style>
  html {
    overflow: hidden;
  }
</style>
