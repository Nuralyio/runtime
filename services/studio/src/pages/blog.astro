---
import Layout from './_layouts/LandingLayout.astro';
import "../shared/ui/components/runtime/MicroApp/MicroApp";
import { MicroApp } from '../shared/ui/components/runtime/MicroApp/MicroApp';
import { processHeaders } from '../features/runtime/utils/api-calls-utils';
import { fetchApplicationPagesById, fetchApplicationComponentById, fetchAllApplications } from '../services';

const blogAPPUUID = process.env.BLOG_APP_UUID;
const blogAPPPageUUID = process.env.BLOG_PAGE_UUID;
let pageData, componentData, applications, application;

const processedHeaders = processHeaders(Astro.request.headers);

  // Load application pages, components, and applications in parallel
  const [pageRequest, componentResponse, applicationsRequest] =
    await Promise.all([
    fetchApplicationPagesById(processedHeaders, blogAPPUUID),
    fetchApplicationComponentById(processedHeaders, blogAPPUUID),
    fetchAllApplications(processedHeaders)
  ]);
  pageData = pageRequest.data;


  applications = applicationsRequest.data;
  application = applications.find((application) => application.uuid === blogAPPUUID);

  componentData = componentResponse.data.map((component) => component.component);

---

<script is:inline define:vars={{ pageData, componentData , application}}>
  window.__INITIAL_PAGE_STATE__ = JSON.stringify(pageData);
  window.__INITIAL_COMPONENT_STATE__ = JSON.stringify(componentData);
  window.__INITIAL_CURRENT_APPLICATION_STATE__ = JSON.stringify(application);
  document.documentElement.style.setProperty('--nuraly-page-background-color', pageData[0]?.style?.['--nuraly-page-background-color'] || '#ffffff');
  document.documentElement.style.setProperty('--nuraly-page-background-color-dark', pageData[0]?.style?.['--nuraly-page-background-color-dark'] || '#000000');

</script>
<Layout title="Welcome to Astrolus.">

  <MicroApp
  .prod={true}
  client:load
  mode="preview"
  .uuid={blogAPPUUID}
  .page_uuid={blogAPPPageUUID}
 ></MicroApp>
</Layout>
<style>
  html {
    background-color : var(--nuraly-page-background-color, #ffffff);

  }
  
</style>
