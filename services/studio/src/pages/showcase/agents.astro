      <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
      <circle cx="9" cy="10" r="1" fill="currentColor"/>
      <circle cx="12" cy="10" r="1" fill="currentColor"/>
      <circle cx="15" cy="10" r="1" fill="currentColor"/>
    </svg>`,
    features: ['Knowledge Base RAG', 'Multi-language', 'Ticket Creation'],
    comingSoon: true,
  },
  {
    id: 'data-analyst',
    title: 'Data Analyst Agent',
    description: 'Query databases, generate reports, and visualize data insights using natural language.',
    category: 'Analytics',
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
      <path d="M3 3v18h18"/>
      <path d="M18 17V9"/>
      <path d="M13 17V5"/>
      <path d="M8 17v-3"/>
    </svg>`,
    features: ['SQL Generation', 'Chart Creation', 'Scheduled Reports'],
    comingSoon: true,
  },
  {
    id: 'code-assistant',
    title: 'Code Assistant',
    description: 'Review code, suggest improvements, generate documentation, and help debug issues.',
    category: 'Development',
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
      <polyline points="16 18 22 12 16 6"/>
      <polyline points="8 6 2 12 8 18"/>
    </svg>`,
