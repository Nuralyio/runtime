    comingSoon: true,
  },
  {
    id: 'research-agent',
    title: 'Research Agent',
    description: 'Search the web, summarize articles, and compile research reports on any topic.',
    category: 'Research',
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
      <circle cx="11" cy="11" r="8"/>
      <path d="M21 21l-4.35-4.35"/>
    </svg>`,
    features: ['Web Search', 'Summarization', 'Citation Tracking'],
    comingSoon: true,
  },
  {
    id: 'sales-assistant',
    title: 'Sales Assistant',
    description: 'Qualify leads, draft personalized outreach, and schedule meetings automatically.',
    category: 'Sales',
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
      <path d="M12 2L2 7l10 5 10-5-10-5z"/>
      <path d="M2 17l10 5 10-5M2 12l10 5 10-5"/>
    </svg>`,
    features: ['Lead Scoring', 'Email Drafting', 'CRM Sync'],
    comingSoon: true,
  },
  {
    id: 'content-writer',
    title: 'Content Writer',
    description: 'Generate blog posts, social media content, and marketing copy with your brand voice.',
    category: 'Marketing',
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
      <path d="M12 19l7-7 3 3-7 7-3-3z"/>
      <path d="M18 13l-1.5-7.5L2 2l3.5 14.5L13 18l5-5z"/>
      <path d="M2 2l7.586 7.586"/>
    </svg>`,
