    description: 'Extract data from PDFs, invoices, and forms. Automate document workflows.',
    category: 'Operations',
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
      <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
      <polyline points="14 2 14 8 20 8"/>
      <line x1="16" y1="13" x2="8" y2="13"/>
      <line x1="16" y1="17" x2="8" y2="17"/>
    </svg>`,
    features: ['OCR Extraction', 'Data Validation', 'Auto-routing'],
    comingSoon: true,
  },
  {
    id: 'meeting-assistant',
    title: 'Meeting Assistant',
    description: 'Transcribe meetings, generate summaries, extract action items, and send follow-ups.',
    category: 'Productivity',
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
      <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/>
      <line x1="16" y1="2" x2="16" y2="6"/>
      <line x1="8" y1="2" x2="8" y2="6"/>
      <line x1="3" y1="10" x2="21" y2="10"/>
    </svg>`,
    features: ['Transcription', 'Action Items', 'Calendar Sync'],
    comingSoon: true,
  },
