---
import MakeLayout from "../../../_layouts/MakeLayout.astro";

import "../components/MainPanel/EditorInteractivePanel";
import { TabsPanel } from "../components/MainPanel/TabsPanel";
import { TopbarPanelWrapper } from "../components/TopBar/TopbarWrapper/TopbarWrapper";
import { LeftPanel } from "../components/Layout/LeftPanel";
import { RightPanel } from "../components/Layout/RightPanel";
import { $pages } from "$store/page"
import { $components } from "$store/component/store";
import { $applications } from "$store/apps";
import { processHeaders } from "../../../../utils/api-calls-utils";
import { fetchAllApplications } from "@services/applications.service";
import { fetchApplicationPagesById } from "@services/page.service";
import { fetchApplicationComponentById } from "@services/component.service";
import { EditorSpinner } from '../components/Layout/EditorSpinner'
import { ApplicationNotFound } from "../../../../exceptions/ApplicationNotFound";
const { title, uuid, urls = "" } = Astro.params;

// TODO: handle error
const processedHeaders = processHeaders(Astro.request.headers);

let pageData, componentData, applications, application;
let occurredError = null;
try {

  // Load application pages, components, and applications in parallel
  const [pageRequest, componentResponse, applicationsRequest] =
    await Promise.all([
    fetchApplicationPagesById(processedHeaders, uuid),
    fetchApplicationComponentById(processedHeaders, uuid),
    fetchAllApplications(processedHeaders)
  ]);

  // Handle page data
  pageData = pageRequest.data;
  $pages.set(pageData);

  // Handle component data
  componentData = componentResponse.data.map((component) => component.component);
  $components.set({ [uuid]: componentData });

  // Handle applications data
  applications = applicationsRequest.data;
  $applications.set(applications);
  application = applications.find((application) => application.uuid === uuid);

} catch (error) {

  if(error instanceof ApplicationNotFound) {
    // Handle application not found here
    console.error("Application not found:", error);
    occurredError = "not-found";
  }
}
---

<head> <title>Nuraly - Editing {application?.name}</title> </head>

<MakeLayout title="Make Apps">
  {(() => {
    switch (occurredError) {
      case "not-found":
        return (
          <div class="flex flex-col justify-center items-center h-screen text-gray-800 bg-gray-100 space-y-4">
            <h1 class="text-2xl font-bold">Application Not Found</h1>
            <p>Please check the application ID or try again later.</p>
          </div>
        );
      case "authorization":
        return (
          <div class="flex justify-center items-center h-screen text-gray-800 bg-gray-100">
            <h1 class="text-2xl font-bold">Unauthorized</h1>
            <p>You do not have permission to access this application.</p>
          </div>
        );
      case "unknown":
        return (
          <div class="flex flex-col justify-center items-center h-screen text-gray-800 bg-gray-100 space-y-4">
            <h1 class="text-2xl font-bold">Unexpected Error</h1>
            <p>Something went wrong. Please try again later.</p>
          </div>
        );
      default:
        return (
          <div class="H-full flex flex-wrap mx-auto" style="
">
            <TopbarPanelWrapper client:load>
              <div
                class="border border-blue-300 shadow rounded-md p-4 m-4"
