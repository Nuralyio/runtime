---
import View from "../view.astro";
import { $currentPageId, $pages } from "../../../../store/page"
import { fetchApplicationById} from "$services/applications.service";
import { fetchApplicationPagesById } from "$services/page.service";


import { $components } from "../../../../store/component/store";
import { fetchPageComponentById } from "$services/component.service";
import { processHeaders } from "utils/api-calls-utils";
// here we will handle the routing
const { title, uuid, urls = "" } = Astro.params;

let request = urls?.split("?") ;
let search = "";
const processedHeaders = processHeaders(Astro.request.headers);

/** TODO: move this to utils  */
let contextParam = "";
if (request.length > 1) {
	contextParam = urls[0];
	search = urls[1];
} else {
	contextParam = urls;
}
/** END */

//const searchQuery = new URLSearchParams(search);
let applicationResponse
if(uuid){
	const result = await fetchApplicationById(processedHeaders, uuid)
	if(result.data){
		applicationResponse = result.data
	}
}


---

<div>
	{applicationResponse?.uuid && <div><View app={applicationResponse} /></div>}
	{!applicationResponse?.uuid && <div>Not Found</div>}
</div>

<script define:vars={{ applicationResponse}}>
	window.applicationResponse = applicationResponse;
	
</script>
