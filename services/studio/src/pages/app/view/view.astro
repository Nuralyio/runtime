---
import "../../../features/studio/panels/main-panel/EditorInteractivePanel";
import { TabsPanel } from '../../../features/studio/panels/main-panel/TabsPanel';
import { TopbarPanelWrapper } from '../../../features/studio/panels/top-bar/TopbarWrapper/TopbarWrapper';
import { LeftPanel } from '../../../features/studio/panels/layout/LeftPanel';
import { RightPanel } from '../../../features/studio/panels/layout/RightPanel';
import { $pages, $currentPageId , $currentPageViewPort} from '../../../features/runtime/redux/store/page';
import { allTasks } from "nanostores";
import { $componentWithChildren, $components } from '../../../features/runtime/redux/store/component/store';
import { PageContent } from '../../../features/studio/params/page/Page';
import { processHeaders } from '../../../features/runtime/utils/api-calls-utils';
import { fetchApplicationPagesById, fetchApplicationComponentById, fetchAllApplications } from '../../../services';
import { $applications } from '../../../features/runtime/redux/store/apps';
// TODO: handle error
const { app } = Astro.props;
const processedHeaders = processHeaders(Astro.request.headers);

let pageData, componentData, applications, application;

try {
  // Load application pages, components, and applications in parallel
  const [pageRequest, componentResponse, applicationsRequest] = await Promise.all([
    fetchApplicationPagesById(processedHeaders, app.uuid),
    fetchApplicationComponentById(processedHeaders, app.uuid),
    fetchAllApplications(processedHeaders)
  ]);

  // Handle page data
  pageData = pageRequest.data;
  $pages.set(pageData);

  // Handle component data
  componentData = componentResponse.data.map((component) => component.component);
  $components.set({ [app.uuid]: componentData });
  // Handle applications data
  applications = applicationsRequest.data;
  $applications.set(applications);
  application = applications.find((application) => application.uuid === app.uuid);

  // Further processing if needed
} catch (error) {
  // Handle errors here
  console.error("An error occurred while loading data:", error);
}
---
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<PageContent isViewMode="true" client:only="lit" />
<script define:vars={{ pageData, componentData, applications, application }}>
  window.__INITIAL_PAGE_STATE__ = JSON.stringify(pageData);
  window.__INITIAL_COMPONENT_STATE__ = JSON.stringify(componentData);
  window.__INITIAL_APPLICATION_STATE__ = JSON.stringify(applications);
  window.__INITIAL_CURRENT_APPLICATION_STATE__ = JSON.stringify(application);


</script>
<style>
  html {
    overflow: hidden;
  }
 
</style>