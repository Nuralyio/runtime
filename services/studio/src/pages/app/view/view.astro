---
import "../../../features/studio/panels/main-panel/EditorInteractivePanel";
import { $pages } from '../../../features/runtime/redux/store/page';
import { $components } from '../../../features/runtime/redux/store/component/store';
import { PageContent } from '../../../features/studio/params/page/Page';
import { processHeaders } from '../../../features/runtime/utils/api-calls-utils';
import { fetchPublishedSnapshot, fetchAllApplications } from '../../../services';
import { $applications } from '../../../features/runtime/redux/store/apps';

// View mode shows the PUBLISHED version, not the live draft
const { app } = Astro.props;
const processedHeaders = processHeaders(Astro.request.headers);

let pageData: any[] = [];
let componentData: any[] = [];
let applications: any[] = [];
let application: any = null;
let notPublished = false;

try {
  // Fetch published snapshot and applications list in parallel
  const [snapshotResponse, applicationsRequest] = await Promise.all([
    fetchPublishedSnapshot(app.uuid, processedHeaders),
    fetchAllApplications(processedHeaders)
  ]);

  // Handle applications data
  applications = applicationsRequest.data || [];
  $applications.set(applications);
  application = applications.find((a: any) => a.uuid === app.uuid) || app;

  // Handle published snapshot
  if (snapshotResponse.status === "OK" && snapshotResponse.data) {
    const snapshot = snapshotResponse.data;

    // Convert page versions to page format
    pageData = (snapshot.pages || []).map((pv: any) => ({
      uuid: pv.pageId,
      name: pv.name,
      url: pv.url,
      description: pv.description,
      style: pv.style,
      need_authentification: pv.needAuth,
      component_ids: pv.componentIds,
      application_id: app.uuid
    }));
    $pages.set(pageData);

    // Convert component versions to component format
    componentData = (snapshot.components || []).map((cv: any) => ({
      ...cv.componentData,
      uuid: cv.componentId
    }));
    $components.set({ [app.uuid]: componentData });

    // Update application from snapshot if available
    if (snapshot.app) {
      application = {
        ...application,
        name: snapshot.app.name,
        subdomain: snapshot.app.subdomain
      };
    }
  } else {
    // No published version exists
    notPublished = true;
  }
} catch (error) {
  console.error("An error occurred while loading published data:", error);
  notPublished = true;
}
---
<meta name="viewport" content="width=device-width, initial-scale=1.0">

{notPublished ? (
  <div class="not-published">
    <div class="not-published-content">
      <svg xmlns="http://www.w3.org/2000/svg" width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="12" cy="12" r="10"></circle>
        <line x1="12" y1="8" x2="12" y2="12"></line>
        <line x1="12" y1="16" x2="12.01" y2="16"></line>
      </svg>
      <h1>App Not Published</h1>
      <p>This application hasn't been published yet.</p>
      <p class="hint">The app owner needs to publish it from the editor.</p>
    </div>
  </div>
) : (
  <PageContent isViewMode="true" client:only="lit" />
)}

<script define:vars={{ pageData, componentData, applications, application, notPublished }}>
  window.__INITIAL_PAGE_STATE__ = JSON.stringify(pageData);
  window.__INITIAL_COMPONENT_STATE__ = JSON.stringify(componentData);
  window.__INITIAL_APPLICATION_STATE__ = JSON.stringify(applications);
  window.__INITIAL_CURRENT_APPLICATION_STATE__ = JSON.stringify(application);
  window.__IS_VIEW_MODE__ = true;
  window.__NOT_PUBLISHED__ = notPublished;
</script>

<style>
  html {
    overflow: hidden;
  }

  .not-published {
    display: flex;
    justify-content: center;
    align-items: center;
    min-height: 100vh;
    background: linear-gradient(135deg, #f5f7fa 0%, #e4e8ec 100%);
    font-family: system-ui, -apple-system, sans-serif;
  }

  .not-published-content {
    text-align: center;
    padding: 48px;
    background: white;
    border-radius: 16px;
    box-shadow: 0 4px 24px rgba(0, 0, 0, 0.08);
    max-width: 400px;
  }

  .not-published-content svg {
    color: #9ca3af;
    margin-bottom: 24px;
  }

  .not-published-content h1 {
    margin: 0 0 12px;
    font-size: 24px;
    font-weight: 600;
    color: #1f2937;
  }

  .not-published-content p {
    margin: 0;
    font-size: 16px;
    color: #6b7280;
  }

  .not-published-content .hint {
    margin-top: 16px;
    font-size: 14px;
    color: #9ca3af;
  }
</style>