//componentData = await processComponents(componentData);

$components.set(componentData);
let componentTree = [];
componentTree = $componentWithChildrens
  .get()
  .filter((c) => $pages.get()[0].component_ids.includes(c.uuid));
const executeAsyncFnctions = async (components) => {
  for (const component of components) {
    let item = {};
    if (component.parent && component.parent.component_type === "Collection") {
      component.iterations=[];
      if (component.parent.data) {
        for (const item of component.parent.data) {
          component.item = item;
          try {
            const result = await executeCode(
              component,
              component.attributesHandlers?.value,
              {
                component: component,
                components: components,
              },
            );
            component.iterations.push(result);
          } catch (e) {}
        }

      }
    }
    if (component.component_type === "Collection") {
      try {
        const result = await executeCode(
          component,
          component.inputHandlers?.data,
          {
            component: component,
            components: components,
          },
        );

        $components.set([
          ...$components.get().map((c) => {
            if (c.uuid === component.uuid) {
              c.data = result;
            }
            return c;
          }),
        ]);
      } catch (e) {}
    } else {
      if (!component.parameters) {
        component.parameters = { value: "" };
      }
      try {
       
        let val = await executeCode(
          component,
          component.attributesHandlers?.value,
          {
            component: component,
            components: components,
          },
        );

        if (val) {
          $components.set([
            ...$components.get().map((c) => {
              if (c.uuid === component.uuid) {
                c.parameters.value = val;
                // Your logic here
              }
              return c;
            }),
          ]);
        }
      } catch (e) {}
    }
    if (component.childrens) {
      await executeAsyncFnctions(component.childrens);
    }
  }
};

//await executeAsyncFnctions(componentTree);
await allTasks();
