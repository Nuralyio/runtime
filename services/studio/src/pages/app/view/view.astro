import { RightPanel } from "../../../components/pages/studio/Layout/RightPanel";
import { $pages, $currentPageId , $currentPageViewPort} from "../../../store/page/store";
import { allTasks } from "nanostores";
import { $componentWithChildrens, $components } from "$store/component/sotre";
import "../../../components/pages/studio/Page/Page";
import { PageContent } from "../../../components/pages/studio/Page/Page";
const cookie = Astro.request.headers.get("Cookie");
const headers = {};
Astro.request.headers.forEach((value, key) => {
  headers[key] = value;
});
const { app } = Astro.props;
delete headers["connection"];
const pageResponse = await fetch(`http://${process.env.NURALY_SERVICES_HOST || "localhost"}/api/pages/${app.uuid}`, {
  cache: "no-store",

  headers: {
   ...headers
  },
});

const pageData = await pageResponse.json();

$currentPageId.set(pageData[0].uuid);

const componentResponse = await fetch(
  `http://${process.env.NURALY_SERVICES_HOST || "localhost"}/api/components/${app.uuid}`,
  {
    cache: "no-store",
    headers: {
         ...headers
    },
  },
);

async function executeCode(component, code, additionalBody = {}) {
  if (!component.item) {
    component.item = {};
  }
  
  let result = await fetch(`http://${process.env.NURALY_ENGINE_HOST || "localhost:3000"}/run-code`, {
    method: "POST",
    cache: "no-store",
    headers: {
     ...headers
    },
    body: JSON.stringify({
      ...additionalBody,
      code,
    }),
  });
  let text = await result.json();
  return text.result;
}

let componentData = await componentResponse.json();

componentData = componentData.map((component) => {
  return { ...component.component, data: [] };
});
