---
import MakeLayout from "./layouts/MakeLayout.astro";

import "../components/pages/studio/MainPanel/EditorInteractivePanel";
import "../components/shared/blocks/components/Tabs/Tabs";
import "../components/shared/blocks/components/Menu/Menu";
import "../components/shared/blocks/components/ColorPicker/colorpicker";
import "../components/shared/blocks/components/NumberInput/NumberInput";
import "../components/shared/blocks/wrappers/GenerikWrapper/GenerikWrapper";
import "../components/shared/blocks/components/IconButton/iconbutton";
import "../components/shared/blocks/components/Select/Select";
import { TabsPanel } from "../components/pages/studio/MainPanel/TabsPanel";
import { TopbarPanelWrapper } from "../components/pages/studio/TopBar/TopbarWrapper/TopbarWrapper";
import { LeftPanel } from "../components/pages/studio/Layout/LeftPanel";
import { RightPanel } from "../components/pages/studio/Layout/RightPanel";
import { $pages } from "../store/page"
import { $components } from "$store/component/component-sotre";
import { $applications } from "$store/apps";
import { registerContextInWebWorker } from "../utils/context-registration";
import { processHeaders } from "utils/api-calls-utils";
import { fetchAllApplications } from "$services/applications.service";
import { fetchApplicationPagesById } from "$services/page.service";
import { fetchApplicationComponentById } from "$services/component.service";

// TODO: handle error
const { app } = Astro.props;
const processedHeaders = processHeaders(Astro.request.headers);

let pageData, componentData, applications, application;

try {
  // Load application pages, components, and applications in parallel
  const [pageRequest, componentResponse, applicationsRequest] = await Promise.all([
    fetchApplicationPagesById(processedHeaders, app.uuid),
    fetchApplicationComponentById(processedHeaders, app.uuid),
    fetchAllApplications(processedHeaders)
  ]);

  // Handle page data
  pageData = pageRequest.data;
  $pages.set(pageData);

  // Handle component data
  componentData = componentResponse.data.map((component) => component.component);
  $components.set({ [app.uuid]: componentData });

  // Handle applications data
  applications = applicationsRequest.data;
  $applications.set(applications);
  application = applications.find((application) => application.uuid === app.uuid);

  // Further processing if needed
  registerContextInWebWorker({});
} catch (error) {
  // Handle errors here
  console.error("An error occurred while loading data:", error);
}
---

