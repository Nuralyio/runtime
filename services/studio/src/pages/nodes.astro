---
import { ApplicationList } from "./applications/ApplicationList";
import { fetchAllApplications } from "$services/applications.service";
import { processHeaders } from "utils/api-calls-utils";
import { $applications } from "$store/apps";
import { TopbarPanelWrapper } from "./app/studio/components/TopBar/TopbarWrapper/TopbarWrapper";

const processedHeaders = processHeaders(Astro.request.headers);

let applications = [];
let error = false;
const result = await fetchAllApplications(processedHeaders);
if (result.data) {
  $applications.set(result.data); 
  
} else {
  error = true;
}
applications = result.data;
console.log($applications.get())
---
<head>
  <title>Nuraly - applications</title>
  <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
  <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
  <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
  <link rel="manifest" href="/site.webmanifest" />
</head>

<div>
  <div>
    <TopbarPanelWrapper client:load>
      <div
        class="border border-blue-300 shadow rounded-md p-4 m-4"
        style="width :98vw; margin-top: 4%;"
      >
        <div class="animate-pulse flex space-x-4">
          <div class="flex-1 space-y-6 py-1">
            <div class="space-y-3">
              <div class="grid grid-cols-3 gap-4">
                <div class="h-2 bg-slate-500 rounded col-span-2"></div>
                <div class="h-2 bg-slate-500 rounded col-span-1"></div>
              </div>
              <div class="h-2 bg-slate-500 rounded"></div>
            </div>
          </div>
        </div>
      </div>
      <div
        class="border border-blue-300 shadow rounded-md p-4 m-4"
        style="width :98vw; "
      >
        <div class="animate-pulse flex space-x-4">
          <div class="flex-1 space-y-6 py-1">
            <div class="space-y-3">
              <div class="grid grid-cols-3 gap-4">
                <div class="h-2 bg-slate-500 rounded col-span-2"></div>
                <div class="h-2 bg-slate-500 rounded col-span-1"></div>
              </div>
              <div class="h-2 bg-slate-500 rounded"></div>
            </div>
          </div>
        </div>
      </div>
      <div
        class="border border-blue-300 shadow rounded-md p-4 m-4"
        style="width :98vw; "
      >
        <div class="animate-pulse flex space-x-4">
          <div class="flex-1 space-y-6 py-1">
