---
/**
 * Dashboard Workflow Route
 * /dashboard/workflow/{wfId}
 */
export const prerender = false;

const { wfId } = Astro.params;

const initialRoute = {
  type: 'workflow',
  resourceId: wfId,
  pathname: Astro.url.pathname,
  search: Astro.url.search
};
---

<!doctype html>
<html lang="en" data-theme="default-light">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Dashboard - Workflow - Nuraly</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@nuralyui/themes@latest/dist/default.css">
    <style is:global>
      :root {
        --nuraly-color-primary: #14144b;
        --nuraly-color-primary-light: #1e1e6e;
        --nuraly-color-primary-bg: #f0f0f8;
        --nuraly-color-background: #f8fafc;
        --nuraly-color-background-hover: #f1f5f9;
        --nuraly-color-surface: #ffffff;
        --nuraly-color-text: #0f0f3c;
        --nuraly-color-text-secondary: #5c5c7a;
        --nuraly-color-text-tertiary: #8c8ca8;
        --nuraly-color-border: #e8e8f0;
        --nuraly-color-border-subtle: #f1f3f5;
        --nuraly-color-success: #16a34a;
        --nuraly-color-warning: #ca8a04;
        --nuraly-color-danger: #dc2626;
        --nuraly-font-mono: 'SF Mono', 'Fira Code', monospace;
      }
      * { margin: 0; padding: 0; box-sizing: border-box; }
      body {
        font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Arial, sans-serif;
        background: var(--nuraly-color-background);
        color: var(--nuraly-color-text);
        min-height: 100vh;
      }
      dashboard-layout { display: block; min-height: 100vh; }
    </style>
  </head>
  <body>
    <dashboard-layout data-initial-route={JSON.stringify(initialRoute)}></dashboard-layout>

    <script>
      import "../../../features/dashboard";
      import "../../../features/runtime/components";
    </script>
  </body>
</html>
