---
import { ViewTransitions } from 'astro:transitions';
import {ApplicationList} from '../components/pages/applications/ApplicationList';
import { $applications } from '$store/apps';

const cookie = Astro.request.headers.get("Cookie");
const headers = {};
Astro.request.headers.forEach((value, key) => {
  headers[key] = value;
});
const {app} = Astro.props;
delete headers["connection"];
const applciationsResponse = await fetch(`http://${process.env.NURALY_SERVICES_HOST || "localhost"}/api/applications`, {
  headers: {
    ...headers,
    Cookie: cookie,
  },
});

 const applications = await applciationsResponse.json();
 $applications.set(applications);

