---
export const prerender = false;
---

<!doctype html>
<html lang="en" data-theme="default-light">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Dashboard - Nuraly</title>

    <!-- Nuraly UI Theme CSS -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@nuralyui/themes@latest/dist/default.css">

    <style>
      /* Nuraly Design System CSS Variables - aligned with 502/home page design */
      :root {
        /* Primary brand colors - Nuraly navy */
        --nuraly-color-primary: #14144b;
        --nuraly-color-primary-light: #1e1e6e;
        --nuraly-color-primary-dark: #0a0a32;
        --nuraly-color-primary-bg: #f0f0f8;

        /* Background colors */
        --nuraly-color-bg: #f8fafc;
        --nuraly-color-bg-secondary: #f1f5f9;
        --nuraly-color-background: #f8fafc;
        --nuraly-color-background-hover: #f1f5f9;
        --nuraly-color-background-active: #e8e8f0;
        --nuraly-color-surface: #ffffff;

        /* Text colors */
        --nuraly-color-text: #0f0f3c;
        --nuraly-color-text-secondary: #5c5c7a;
        --nuraly-color-text-tertiary: #8c8ca8;
        --nuraly-color-text-muted: #8c8ca8;

        /* Border colors */
        --nuraly-color-border: #e8e8f0;
        --nuraly-color-border-subtle: #f1f3f5;
        --nuraly-color-border-dashed: #d8d8e4;

        /* Status colors */
        --nuraly-color-success: #16a34a;
        --nuraly-color-success-light: #dcfce7;
        --nuraly-color-warning: #ca8a04;
        --nuraly-color-warning-light: #fef9c3;
        --nuraly-color-danger: #dc2626;
        --nuraly-color-danger-light: #fee2e2;
        --nuraly-color-info: #0891b2;
        --nuraly-color-info-light: #cffafe;

        /* Additional colors */
        --nuraly-color-purple: #722ed1;
        --nuraly-color-purple-light: #f9f0ff;

        /* Button colors - Override NuralyUI defaults to use Nuraly brand */
        --nuraly-color-button-primary: var(--nuraly-color-primary);
        --nuraly-color-button-primary-hover: var(--nuraly-color-primary-light);
        --nuraly-color-button-primary-active: var(--nuraly-color-primary-dark);
        --nuraly-color-button-primary-text: #ffffff;

        /* Typography */
        --nuraly-font-mono: 'SF Mono', 'Fira Code', 'Fira Mono', Menlo, monospace;

        /* Transitions */
        --nuraly-transition: 150ms ease;

        /* Footer colors */
        --nuraly-footer-bg: #0a0a32;
        --nuraly-footer-text: #6666a0;
        --nuraly-footer-link: #8888b0;
      }

      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }

      html {
        scroll-behavior: smooth;
      }

      body {
        font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif;
        background: var(--nuraly-color-background);
        color: var(--nuraly-color-text);
        line-height: 1.6;
        -webkit-font-smoothing: antialiased;
        min-height: 100vh;
      }

      nuraly-dashboard {
        display: block;
        width: 100%;
        min-height: 100vh;
      }
    </style>
  </head>
  <body>
    <nuraly-dashboard></nuraly-dashboard>

    <script>
      // Import and register all dashboard components
      import "../features/dashboard";

      // Also import runtime components for NuralyUI
      import "../features/runtime/components";
    </script>
  </body>
</html>
