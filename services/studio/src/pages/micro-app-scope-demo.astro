---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Variable Scope Demo - Nuraly Studio</title>
    <style>
      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }

      body {
        font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
        background: #f9fafb;
        min-height: 100vh;
        padding: 20px;
      }

      .demo-container {
        max-width: 1400px;
        margin: 0 auto;
      }

      .demo-header {
        margin-bottom: 24px;
        text-align: center;
      }

      .demo-header h1 {
        font-size: 28px;
        color: #111827;
        margin-bottom: 8px;
      }

      .demo-header p {
        font-size: 14px;
        color: #6b7280;
        margin-bottom: 4px;
      }

      .scope-legend {
        display: flex;
        justify-content: center;
        gap: 24px;
        margin-top: 16px;
        padding: 12px;
        background: white;
        border-radius: 8px;
        border: 1px solid #e5e7eb;
      }

      .scope-legend-item {
        display: flex;
        align-items: center;
        gap: 8px;
        font-size: 13px;
      }

      .scope-badge {
        padding: 4px 8px;
        border-radius: 4px;
        font-weight: 600;
        font-size: 11px;
      }

      .scope-local { background: #e0f2fe; color: #0c4a6e; }
      .scope-global { background: #ede9fe; color: #5b21b6; }

      .instances-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
        gap: 20px;
        margin-top: 24px;
      }

      .micro-app-wrapper {
        background: white;
        border: 1px solid #e5e7eb;
        border-radius: 8px;
        padding: 8px;
        min-height: 300px;
      }

      micro-app {
        display: block;
        width: 100%;
      }

      .instructions {
        background: #dbeafe;
        border: 1px solid #3b82f6;
        border-radius: 8px;
        padding: 16px;
        margin-bottom: 20px;
      }

      .instructions h3 {
        font-size: 16px;
        color: #1e3a8a;
        margin-bottom: 8px;
      }

      .instructions ul {
        list-style: none;
        padding-left: 0;
      }

      .instructions li {
        font-size: 13px;
        color: #1e40af;
        margin-bottom: 4px;
        padding-left: 20px;
        position: relative;
      }

      .instructions li:before {
        content: "→";
        position: absolute;
        left: 0;
      }
    </style>
  </head>
  <body>
    <div class="demo-container">
      <div class="demo-header">
        <h1>Variable Scope Demo</h1>
        <p>Three micro-app instances demonstrating LOCAL and GLOBAL variable scopes</p>

        <div class="scope-legend">
          <div class="scope-legend-item">
            <span class="scope-badge scope-local">LOCAL</span>
            <span>Isolated per instance</span>
          </div>
          <div class="scope-legend-item">
            <span class="scope-badge scope-global">GLOBAL</span>
            <span>Shared across all instances</span>
          </div>
        </div>
      </div>

      <div class="instructions">
        <h3>Try it out:</h3>
        <ul>
          <li><strong>LOCAL (Blue):</strong> Each instance has its own isolated counter - clicking in one doesn't affect others</li>
          <li><strong>GLOBAL (Purple):</strong> All instances share the same counter - clicking in any instance updates all displays</li>
        </ul>
      </div>

      <div class="instances-grid">
        <div class="micro-app-wrapper">
          <micro-app id="instance-1"></micro-app>
        </div>

        <div class="micro-app-wrapper">
          <micro-app id="instance-2"></micro-app>
        </div>

        <div class="micro-app-wrapper">
          <micro-app id="instance-3"></micro-app>
        </div>
      </div>
    </div>

    <script is:inline define:vars={{
      instance1AppId,
      instance2AppId,
      instance3AppId,
      instance1Components,
      instance2Components,
      instance3Components,
      instance1Pages,
      instance2Pages,
      instance3Pages
    }}>
      window.scopeDemoData = {
        instance1AppId,
        instance2AppId,
        instance3AppId,
        instance1Components,
        instance2Components,
        instance3Components,
        instance1Pages,
        instance2Pages,
        instance3Pages,
      };
    </script>

    <script>

      import "@shared/ui/components/runtime/MicroApp/MicroApp";

      document.addEventListener("DOMContentLoaded", () => {
        const data = window.scopeDemoData;

        // Instance 1
        const instance1 = document.getElementById("instance-1");
        if (instance1) {
          instance1.uuid = data.instance1AppId;
          instance1.page_uuid = "page-inst1";
          instance1.useIsolatedContext = true;
          instance1.appComponents = data.instance1Components;
          instance1.appPages = data.instance1Pages;
          instance1.mode = "preview";
          instance1.prod = true;
        }

        // Instance 2
        const instance2 = document.getElementById("instance-2");
        if (instance2) {
          instance2.uuid = data.instance2AppId;
          instance2.page_uuid = "page-inst2";
          instance2.useIsolatedContext = true;
          instance2.appComponents = data.instance2Components;
          instance2.appPages = data.instance2Pages;
          instance2.mode = "preview";
          instance2.prod = true;
        }

        // Instance 3
        const instance3 = document.getElementById("instance-3");
        if (instance3) {
          instance3.uuid = data.instance3AppId;
          instance3.page_uuid = "page-inst3";
          instance3.useIsolatedContext = true;
          instance3.appComponents = data.instance3Components;
          instance3.appPages = data.instance3Pages;
          instance3.mode = "preview";
          instance3.prod = true;
        }
      });
    </script>
  </body>
</html>
