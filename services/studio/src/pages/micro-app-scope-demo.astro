---
/**
 * Micro App Variable Scope Demo
 *
 * This page demonstrates the two-level variable scope system:
 * - LOCAL: Isolated to each micro-app instance
 * - GLOBAL: Shared across all micro-apps
 */

// Disable server-side rendering
export const prerender = false;

// Unique App IDs for each instance
const instance1AppId = "scope-demo-instance-1";
const instance2AppId = "scope-demo-instance-2";
const instance3AppId = "scope-demo-instance-3";

// Pages for Instance 1
const instance1Pages = [
  {
    uuid: "page-inst1",
    application_id: instance1AppId,
    name: "Instance 1 Page",
    url: "/inst1",
    description: "Instance 1 page",
    is_default: true,
  },
];

// Pages for Instance 2
const instance2Pages = [
  {
    uuid: "page-inst2",
    application_id: instance2AppId,
    name: "Instance 2 Page",
    url: "/inst2",
    description: "Instance 2 page",
    is_default: true,
  },
];

// Pages for Instance 3
const instance3Pages = [
  {
    uuid: "page-inst3",
    application_id: instance3AppId,
    name: "Instance 3 Page",
    url: "/inst3",
    description: "Instance 3 page",
    is_default: true,
  },
];

// Components for Micro-App Instance 1
const instance1Components = [
  {
    uuid: "inst1-container",
    name: "Instance 1 Container",
    component_type: "vertical-container-block",
    application_id: instance1AppId,
    pageId: "page-inst1",
    root: true,
    childrenIds: ["inst1-title", "inst1-local-btn", "inst1-global-btn", "inst1-display"],
    style: {
      display: "flex",
      flexDirection: "column",
      gap: "12px",
      padding: "20px",
      backgroundColor: "#e0f2fe",
      borderRadius: "8px",
      border: "2px solid #0ea5e9",
    },
  },
  {
    uuid: "inst1-title",
    name: "Instance 1 Title",
    component_type: "text_label",
    application_id: instance1AppId,
    pageId: "page-inst1",
    root: false,
    style: { fontSize: "18px", fontWeight: "bold", color: "#0c4a6e" },
    input: { value: { type: "string", value: "Instance 1" } },
  },
  {
    uuid: "inst1-local-btn",
    name: "Set LOCAL Button",
    component_type: "button_input",
    application_id: instance1AppId,
    pageId: "page-inst1",
    root: false,
    event: {
      onClick: `
        Vars.localCounter = (Vars.localCounter || 0) + 1;
        console.log('[Instance 1] LOCAL counter:', Vars.localCounter);
      `,
    },
    input: { label: { type: "string", value: "Set LOCAL Variable" } },
  },
  {
    uuid: "inst1-global-btn",
    name: "Set GLOBAL Button",
    component_type: "button_input",
    application_id: instance1AppId,
    pageId: "page-inst1",
    root: false,
    event: {
      onClick: `
        Vars['global.universalCounter'] = (Vars['global.universalCounter'] || 0) + 1;
        console.log('[Instance 1] GLOBAL counter:', Vars['global.universalCounter']);
      `,
    },
    input: { label: { type: "string", value: "Set GLOBAL Variable" } },
    style: { backgroundColor: "#8b5cf6", borderColor: "#8b5cf6" },
  },
  {
    uuid: "inst1-display",
    name: "Instance 1 Display",
    component_type: "text_label",
    application_id: instance1AppId,
    pageId: "page-inst1",
    root: false,
    style: { fontSize: "12px", color: "#334155", fontFamily: "monospace", whiteSpace: "pre-line" },
    input: {
      value: {
        type: "handler",
        value: `
          const local = Vars.localCounter || 0;
          const global = Vars['global.universalCounter'] || 0;
          return 'LOCAL: ' + local + '\\nGLOBAL: ' + global;
        `,
      },
    },
  },
];

