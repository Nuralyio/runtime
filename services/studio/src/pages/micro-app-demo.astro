    </script>
    
    <style>
      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }

      body {
        font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
        background: #f9fafb;
        min-height: 100vh;
        padding: 20px;
      }

      .demo-container {
        max-width: 900px;
        margin: 0 auto;
      }

      .demo-header {
        margin-bottom: 24px;
      }

      .demo-header h1 {
        font-size: 24px;
        color: #111827;
        margin-bottom: 4px;
      }

      .demo-header p {
        font-size: 14px;
        color: #6b7280;
      }

      .micro-app-wrapper {
        background: white;
        border: 1px solid #e5e7eb;
        border-radius: 8px;
        padding: 16px;
      }

      micro-app {
        display: block;
        width: 100%;
      }
    </style>
  </head>
  <body>
    <div class="demo-container">
      <div class="demo-header">
        <h1>Micro App Demo</h1>
        <p>Isolated runtime with variable scoping</p>
      </div>

      <div class="micro-app-wrapper" id="micro-app-container">
        <!-- MicroApp will be created dynamically after properties are ready -->
      </div>
    </div>

    <script is:inline define:vars={{ appId, appComponents, appPages }}>
      // This script has access to the server-side variables via define:vars
      window.appData = {
        appId,
        appComponents,
        appPages,
      };
      console.log('[Micro App Demo] appData prepared:', window.appData);
    </script>
  <link rel="stylesheet" 
  href="https://cdn.jsdelivr.net/npm/@nuraly/runtime@0.1.0/dist/style.css">
    <!-- Load the bundled MicroApp runtime with all dependencies included -->
     <link rel="stylesheet"
  href="https://cdn.jsdelivr.net/npm/@nuralyui/themes@latest/dist/default.css">

    <script type="module">
      import "@nuraly/runtime";

      // Wait for DOM and component to be ready
      async function initializeMicroApp() {
        console.log('[Micro App Demo] Starting initialization...');

        // Wait for the custom element to be defined
        await customElements.whenDefined('micro-app');
        console.log('[Micro App Demo] micro-app custom element is defined');

        console.log('[Micro App Demo] window.appData:', window.appData);

        if (!window.appData) {
          console.error('[Micro App Demo] window.appData not found!');
          return;
        }

        // Create the micro-app element
        const microApp = document.createElement('micro-app');
        microApp.id = 'demo-micro-app';

        // Set properties BEFORE adding to DOM
        microApp.uuid = window.appData.appId;
        microApp.page_uuid = "page-001";
        microApp.useIsolatedContext = true;
        microApp.appComponents = window.appData.appComponents;
        microApp.appPages = window.appData.appPages;
        microApp.mode = "preview";
        microApp.prod = true;

        console.log('[Micro App Demo] MicroApp properties set (before connection):', {
          uuid: microApp.uuid,
          page_uuid: microApp.page_uuid,
          useIsolatedContext: microApp.useIsolatedContext,
          componentsCount: microApp.appComponents?.length,
          pagesCount: microApp.appPages?.length,
          mode: microApp.mode,
          prod: microApp.prod
        });

        // Add to DOM - this triggers connectedCallback
        const container = document.getElementById('micro-app-container');
        if (container) {
          container.appendChild(microApp);
          console.log('[Micro App Demo] MicroApp element added to DOM');
        } else {
          console.error('[Micro App Demo] Container not found!');
        }
      }

      // Initialize when DOM is ready
      if (document.readyState === 'loading') {
        document.addEventListener("DOMContentLoaded", initializeMicroApp);
      } else {
        // DOM already loaded
        initializeMicroApp();
      }
    </script>
  </body>
</html>
