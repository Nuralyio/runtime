{
  "name": "civil-chroma",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev  --host ",
    "build": "astro build --verbose ",
    "preview": "astro preview",
    "server": "HOST=0.0.0.0 PORT=4321 node ./dist/server/entry.mjs",
    "astro": "astro",
    "update": "ncu --color --cacheClear \"/^@nuralyui.*$/\" -u",
    "link": "node -e \"const fs = require('fs'); const pkgs = fs.readdirSync('node_modules/@nuralyui').map(p => '@nuralyui/' + p).join(' '); require('child_process').execSync('npm link ' + pkgs, { stdio: 'inherit' });\"",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:all": "vitest run && playwright test"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.4",
