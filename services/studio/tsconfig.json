{
  "extends": "astro/tsconfigs/base",
  "compilerOptions": {
    "jsx": "react-jsx",
    "experimentalDecorators": true,
    "jsxImportSource": "preact",
    "useDefineForClassFields": false,
    "baseUrl": "./src",
    "paths": {
      "$store/*": [
        "store/*"
      ],
      "@shared/*": [
        "shared/*"
      ],
      "@services/*": [
        "services/*"
      ],
      "@utils/*": [
        "utils/*"
      ]
    },
    "target": "esnext",
  }
}