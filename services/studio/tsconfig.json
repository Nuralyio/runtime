{
  "extends": "astro/tsconfigs/base",
  "compilerOptions": {
    "jsx": "react-jsx",
    "experimentalDecorators": true,
    "jsxImportSource": "preact",
    "useDefineForClassFields": false,
    "baseUrl": "./src",
    "paths": {
      "$store/*": [
        "shared/redux/store/*"
      ],
      "@features/*": [
        "features/*"
      ],
      "@shared/*": [
        "shared/*"
      ],
      "@services/*": [
        "services/*" 
      ],
      "@runtime/*": [
        "features/runtime/*"
      ],
      "@studio/*": [
        "features/studio/*"
      ],
      "@nuralyui/*": [
        "shared/ui/nuraly-ui/src/components/*"
      ],
      "@nuralyui/common/mixins": [
        "shared/ui/nuraly-ui/packages/common/src"
      ]
    },
    "target": "esnext",
  },
  "exclude": ["node_modules", "dist"]
}