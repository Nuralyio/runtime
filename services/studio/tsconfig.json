{
  "extends": "astro/tsconfigs/base",
  "compilerOptions": {
    "jsx": "react-jsx",
    "experimentalDecorators": true,
    "jsxImportSource": "preact",
    "useDefineForClassFields": false,
    "baseUrl": "./src",
    "paths": {
      "$store/*": [
        "shared/redux/store/*"
      ],
      "@features/*": [
        "features/*"
      ],
      "@shared/*": [
        "shared/*"
      ],
      "@api/*": [
        "api/*"
      ],
      "@runtime/*": [
        "features/runtime/*"
      ],
      "@studio/*": [
        "features/studio/*"
      ],
      "@utils/*": [
        "utils/*"
      ]
    },
    "target": "esnext",
  },
  "exclude": ["node_modules", "dist"]
}