{
  "extends": "astro/tsconfigs/base",
  "compilerOptions": {
    "jsx": "react-jsx",
    "experimentalDecorators": true,
    "jsxImportSource": "preact",
    "useDefineForClassFields": false,
    "baseUrl": "./src",
    "target": "esnext",
    "paths": {
      "@nuraly/runtime": ["./features/runtime"],
      "@nuraly/runtime/*": ["./features/runtime/*"]
    }
  },
  "exclude": ["node_modules", "dist"]
}