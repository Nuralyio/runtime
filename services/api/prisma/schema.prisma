datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Product {
  id        String   @id @default(uuid())
  name      String
  price     Float
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  //applications  applications[]
}

model applications {
  id                Int      @id @default(autoincrement())
  name              String   @default("")
  published         Boolean? @default(false)
  uuid              String   @unique @default("")
  user_id           String
  //user        User @relation(fields: [user_id], references: [id])
  default_page_uuid String?
}

// ============================================
// ACCESS CONTROL MODELS (New 3-Table Architecture)
// ============================================

// Application Roles - System roles + custom roles per application
model ApplicationRole {
  id            Int       @id @default(autoincrement())
  applicationId String?   @map("application_id") // NULL for system roles
  name          String
  displayName   String    @map("display_name")
  description   String?
  permissions   Json      // Array of permission strings: ["application:read", "page:*"]
  isSystem      Boolean   @default(false) @map("is_system")
  hierarchy     Int       @default(0) // Higher = more permissions (owner=100, admin=80, etc.)
  createdAt     DateTime  @default(now()) @map("created_at")

  members ApplicationMember[]

  @@unique([applicationId, name])
  @@index([applicationId])
  @@index([isSystem])
  @@map("application_roles")
}

// Application Members - User role assignments within applications
model ApplicationMember {
  id            Int      @id @default(autoincrement())
  userId        String   @map("user_id")
  applicationId String   @map("application_id")
  roleId        Int      @map("role_id")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  role ApplicationRole @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([userId, applicationId])
  @@index([applicationId])
  @@index([userId])
  @@index([roleId])
  @@map("application_members")
}

// Resource Permissions - Fine-grained access control for specific resources
model ResourcePermission {
  id           Int       @id @default(autoincrement())
  resourceId   String    @map("resource_id")
  resourceType String    @map("resource_type") // page, component, file, application
  granteeType  String    @map("grantee_type")  // user, role, public, anonymous
  granteeId    String?   @map("grantee_id")    // User UUID or Role ID (NULL for public/anonymous)
  permission   String                          // read, write, delete, share
  grantedBy    String    @map("granted_by")    // User who granted this permission
  expiresAt    DateTime? @map("expires_at")    // Optional expiration (NULL = permanent)
  createdAt    DateTime  @default(now()) @map("created_at")

  @@unique([resourceId, resourceType, granteeType, granteeId, permission])
  @@index([resourceId, resourceType])
  @@index([granteeId, granteeType])
  @@index([expiresAt])
  @@map("resource_permissions")
}

model components {
  id             Int    @id @default(autoincrement())
  component      Json
  user_id        String @default("")
  uuid           String @unique
  application_id String @default("")
}

model pages {
  id                    Int      @id @default(autoincrement())
  component_ids         String[] @default([])
  style                 Json     @default("{}")
  name                  String
  url                   String
  description           String  @default("")
  application_id        String
  user_id               String
  uuid                  String @unique
  need_authentification Boolean  @default(false) @map("need_authentication")

  @@map("pages")
}

model databaseproviders {
  provider_id   Int    @id @default(autoincrement())
  username      String @default("")
  host          String @default("")
  password      String @default("")
  port          Int    @default(0)
  databasename  String @default("")
  provider_type String @default("")
  component_ids Json  @default("[]")
  user_id       String
  label         String

  @@map("databaseproviders")
}
