datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Product {
  id        String   @id @default(uuid())
  name      String
  price     Float
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model User {
  id         String   @id @default(uuid())
  keycloakId String?  @unique @map("keycloak_id") // Keycloak user UUID (sub claim)
  name       String
  email      String   @unique
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model applications {
  id                Int      @id @default(autoincrement())
  name              String   @default("")
  published         Boolean? @default(false)
  uuid              String   @unique @default("")
  user_id           String
  //user        User @relation(fields: [user_id], references: [id])
  default_page_uuid String?
  subdomain         String?  @unique // Unique subdomain for accessing the app (e.g., "myapp" for myapp.domain.com)
  requiresAuthOnly  Boolean  @default(false) @map("requires_auth_only") // When true, any authenticated user can access (no role/member check needed)
  i18n              Json?    // Internationalization config: { defaultLocale, supportedLocales, fallbackLocale }
}

// ============================================
// ACCESS CONTROL MODELS (New 3-Table Architecture)
// ============================================

// Application Roles - System roles + custom roles per application
model ApplicationRole {
  id            Int       @id @default(autoincrement())
  applicationId String?   @map("application_id") // NULL for system roles
  name          String
  displayName   String    @map("display_name")
  description   String?
  permissions   Json      // Array of permission strings: ["application:read", "page:*"]
  isSystem      Boolean   @default(false) @map("is_system")
  hierarchy     Int       @default(0) // Higher = more permissions (owner=100, admin=80, etc.)
  createdAt     DateTime  @default(now()) @map("created_at")

  members        ApplicationMember[]
  pendingInvites PendingInvite[]

  @@unique([applicationId, name])
  @@index([applicationId])
  @@index([isSystem])
  @@map("application_roles")
}

// Pending Invites - Email invites for users not yet registered
model PendingInvite {
  id            Int       @id @default(autoincrement())
  email         String
  applicationId String    @map("application_id")
  roleId        Int       @map("role_id")
  invitedBy     String    @map("invited_by")  // User ID of inviter
  token         String    @unique @default(uuid())  // For invite link
  expiresAt     DateTime  @map("expires_at")
  createdAt     DateTime  @default(now()) @map("created_at")

  role ApplicationRole @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([email, applicationId])
  @@index([email])
  @@index([applicationId])
  @@index([token])
  @@map("pending_invites")
}

// Application Members - User role assignments within applications
model ApplicationMember {
  id            Int      @id @default(autoincrement())
  userId        String   @map("user_id")
  applicationId String   @map("application_id")
  roleId        Int      @map("role_id")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  role ApplicationRole @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([userId, applicationId])
  @@index([applicationId])
  @@index([userId])
  @@index([roleId])
  @@map("application_members")
}

// Resource Permissions - Fine-grained access control for specific resources
model ResourcePermission {
  id           Int       @id @default(autoincrement())
  resourceId   String    @map("resource_id")
  resourceType String    @map("resource_type") // page, component, file, application
  granteeType  String    @map("grantee_type")  // user, role, public, anonymous
  granteeId    String?   @map("grantee_id")    // User UUID or Role ID (NULL for public/anonymous)
  permission   String                          // read, write, delete, share
  grantedBy    String    @map("granted_by")    // User who granted this permission
  expiresAt    DateTime? @map("expires_at")    // Optional expiration (NULL = permanent)
  createdAt    DateTime  @default(now()) @map("created_at")

  @@unique([resourceId, resourceType, granteeType, granteeId, permission])
  @@index([resourceId, resourceType])
  @@index([granteeId, granteeType])
  @@index([expiresAt])
  @@map("resource_permissions")
}

model components {
  id             Int    @id @default(autoincrement())
  component      Json
  user_id        String @default("")
  uuid           String @unique
  application_id String @default("")
}

model pages {
  id                    Int      @id @default(autoincrement())
  component_ids         String[] @default([])
  style                 Json     @default("{}")
  name                  String
  url                   String
  description           String  @default("")
  application_id        String
  user_id               String
  uuid                  String @unique
  need_authentification Boolean  @default(false) @map("need_authentication")

  @@map("pages")
}

model databaseproviders {
  provider_id   Int    @id @default(autoincrement())
  username      String @default("")
  host          String @default("")
  password      String @default("")
  port          Int    @default(0)
  databasename  String @default("")
  provider_type String @default("")
  component_ids Json  @default("[]")
  user_id       String
  label         String

  @@map("databaseproviders")
}

// ============================================
// REVISION SYSTEM - Version History
// ============================================

// Application metadata versions
model ApplicationVersion {
  id            String   @id @default(uuid())
  applicationId String   @map("application_id")
  version       Int
  name          String
  subdomain     String?
  defaultPageId String?  @map("default_page_id")
  createdBy     String   @map("created_by")
  createdAt     DateTime @default(now()) @map("created_at")

  @@unique([applicationId, version])
  @@index([applicationId])
  @@map("application_versions")
}

// Page versions
model PageVersion {
  id            String   @id @default(uuid())
  pageId        String   @map("page_id")
  applicationId String   @map("application_id")
  version       Int
  name          String
  url           String
  description   String   @default("")
  style         Json     @default("{}")
  needAuth      Boolean  @default(false) @map("need_authentication")
  componentIds  String[] @map("component_ids")
  createdBy     String   @map("created_by")
  createdAt     DateTime @default(now()) @map("created_at")

  @@unique([pageId, version])
  @@index([pageId])
  @@index([applicationId])
  @@map("page_versions")
}

// Component versions
model ComponentVersion {
  id            String   @id @default(uuid())
  componentId   String   @map("component_id")
  applicationId String   @map("application_id")
  version       Int
  componentData Json     @map("component_data")
  createdBy     String   @map("created_by")
  createdAt     DateTime @default(now()) @map("created_at")

  @@unique([componentId, version])
  @@index([componentId])
  @@index([applicationId])
  @@map("component_versions")
}

// Application revision - references specific versions
model ApplicationRevision {
  id            String   @id @default(uuid())
  applicationId String   @map("application_id")
  revision      Int
  versionLabel  String?  @map("version_label")
  description   String?
  appVersion    Int      @map("app_version")
  pageRefs      Json     @map("page_refs")       // [{ pageId, version }, ...]
  componentRefs Json     @map("component_refs")  // [{ componentId, version }, ...]
  createdBy     String   @map("created_by")
  createdAt     DateTime @default(now()) @map("created_at")

  @@unique([applicationId, revision])
  @@index([applicationId])
  @@map("application_revisions")
}

// Published version tracker
model PublishedVersion {
  id            String   @id @default(uuid())
  applicationId String   @unique @map("application_id")
  revision      Int
  publishedBy   String   @map("published_by")
  publishedAt   DateTime @default(now()) @map("published_at")

  @@map("published_versions")
}
