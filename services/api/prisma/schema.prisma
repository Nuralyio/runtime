datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Product {
  id        String   @id @default(uuid())
  name      String
  price     Float
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  //applications  applications[]
}

model applications {
  id                Int      @id @default(autoincrement())
  name              String   @default("")
  published         Boolean? @default(false)
  uuid              String   @unique @default("")
  user_id           String
  //user        User @relation(fields: [user_id], references: [id])
  default_page_uuid String?
}

model Permission {
  id             Int     @id @default(autoincrement())
  userId         String  @map("user_id")
  resourceId     String  @map("resource_id")
  resourceType   String  @map("resource_type")
  publicState    Boolean @map("public")
  permissionType String  @map("permission_type")
  ownerId        String  @map("owner_id")
  allowed        Json

  @@map("permissions")
}

model Ownership {
  id           Int    @id @default(autoincrement())
  ownerId      String @map("owner_id")
  resourceId   String @map("resource_id")
  resourceType String @map("resource_type")

  @@map("ownership")
}

model components {
  id             Int    @id @default(autoincrement())
  component      Json
  user_id        String @default("")
  uuid           String @unique
  application_id String @default("")
}

model pages {
  id                    Int      @id @default(autoincrement())
  component_ids         String[] @default([])
  name                  String
  url                   String
  application_id        String
  user_id               String
  uuid                  String
  need_authentification Boolean  @default(false) @map("need_authentication")

  @@map("pages")
}

model databaseproviders {
  provider_id   Int    @id @default(autoincrement())
  username      String @default("")
  host          String @default("")
  password      String @default("")
  port          Int    @default(0)
  databasename  String @default("")
  provider_type String @default("")
  component_ids Json  @default("[]")
  user_id       String
  label         String

  @@map("databaseproviders")
}
