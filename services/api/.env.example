BACKEND_PORT=3000
DATABASE_URL="postgresql://postgres:123@localhost:5432/bd_node"
SECRET_KEY="your-key"
TOKEN_EXPIRY="2h"

# Gateway Security (P0 - Critical)
# Shared secret between API gateway and this service for X-USER header validation
TRUSTED_GATEWAY_SECRET="your-gateway-secret-here"
# Set to "true" to enforce gateway validation (recommended for production)
ENFORCE_GATEWAY_VALIDATION="false"