# Development Environment Variables
NODE_ENV=development

# Database
DATABASE_URL=postgresql://postgres:password@postgres:5432/nuraly_dev
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
POSTGRES_DB=nuraly_dev

# Redis
REDIS_URL=redis://redis:6379
REDIS_PASSWORD=

# JWT
JWT_SECRET=your-dev-jwt-secret-key
JWT_EXPIRES_IN=7d

# API Keys (Development)
API_KEY=dev-api-key
ENCRYPTION_KEY=your-dev-encryption-key

# External Services (Development)
SMTP_HOST=mailhog
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@nuraly.dev

# AWS (Development - LocalStack)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
AWS_ENDPOINT_URL=http://localstack:4566

# Logging
LOG_LEVEL=debug
LOG_FORMAT=dev

# CORS
CORS_ORIGIN=http://localhost:3000

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# File Upload
MAX_FILE_SIZE=10485760
UPLOAD_PATH=/tmp/uploads