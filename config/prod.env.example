# Production Environment Variables
# Copy this file to prod.env and fill in the values
NODE_ENV=production

# Database (Always runs in production)
DATABASE_URL=postgresql://postgres:${POSTGRES_PASSWORD}@postgres:5432/nuraly_prod
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME_SECURE_PASSWORD
POSTGRES_DB=nuraly_prod

# Redis
REDIS_URL=redis://redis:6379
REDIS_PASSWORD=CHANGE_ME_SECURE_PASSWORD

# Keycloak - Authentication & Authorization
KEYCLOAK_URL=https://auth.yourdomain.com/auth
KEYCLOAK_REALM=nuraly-prod
KEYCLOAK_CLIENT_ID=nuraly-web
KEYCLOAK_CLIENT_SECRET=CHANGE_ME_CLIENT_SECRET
KEYCLOAK_ADMIN_USERNAME=admin
KEYCLOAK_ADMIN_PASSWORD=CHANGE_ME_SECURE_PASSWORD
KEYCLOAK_ADMIN_USER_PASSWORD=CHANGE_ME_INITIAL_ADMIN_USER_PASSWORD
# Gateway Keycloak settings
KC_HOSTNAME=localhost
KEYCLOAK_SCHEME=http
KEYCLOAK_FULLURL=http://localhost
# Production User (auto-created on initialization)
KEYCLOAK_PROD_USER_ID=7a44cfff-24d1-4eec-8974-c6384303f1ba
KEYCLOAK_PROD_USER_EMAIL=admin@yourdomain.com

# JWT
JWT_SECRET=CHANGE_ME_GENERATE_SECURE_RANDOM_STRING_64_CHARS
JWT_EXPIRES_IN=24h

# API Keys (Production)
API_KEY=CHANGE_ME_API_KEY
ENCRYPTION_KEY=CHANGE_ME_ENCRYPTION_KEY

# External Services (Production)
SMTP_HOST=smtp.your-email-provider.com
SMTP_PORT=587
SMTP_USER=your-smtp-user
SMTP_PASS=CHANGE_ME_SMTP_PASSWORD
SMTP_FROM=noreply@yourdomain.com

# AWS (Production)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=CHANGE_ME_AWS_KEY
AWS_SECRET_ACCESS_KEY=CHANGE_ME_AWS_SECRET
AWS_S3_BUCKET=your-s3-bucket

# Domain
DOMAIN=yourdomain.com
FRONTEND_URL=https://yourdomain.com
API_URL=https://yourdomain.com/api

# SSL - Managed by Cloudflare (no local SSL config needed)

# Logging
LOG_LEVEL=info
LOG_FORMAT=combined

# CORS
CORS_ORIGIN=https://yourdomain.com

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=60

# File Upload
MAX_FILE_SIZE=5242880
UPLOAD_PATH=/app/uploads

# Monitoring
GRAFANA_PASSWORD=CHANGE_ME_SECURE_PASSWORD

# Security
HELMET_CSP_ENABLED=true
HELMET_HSTS_ENABLED=true

# Dashboard Application
DASHBOARD_APP_UUID=your-dashboard-app-uuid
DASHBOARD_PAGE_UUID=your-dashboard-page-uuid

# Home Page Application
HOME_APP_UUID=your-home-app-uuid
HOME_PAGE_UUID=your-home-page-uuid

# Blog Application
BLOG_APP_UUID=your-blog-app-uuid
BLOG_PAGE_UUID=your-blog-page-uuid

# Documentation Application
DOCS_APP_UUID=your-docs-app-uuid
DOCS_PAGE_UUID=your-docs-page-uuid

# Function Application
FUNCTION_APP_UUID=your-function-app-uuid
FUNCTION_PAGE_UUID=your-function-page-uuid

